// MARK: - Keychain Service

/// Service for securely storing subscription data in Keychain
public class KeychainService {
    private let serviceName = "ai.folktech.serena.subscription"

    func saveLicenseKey(_ key: String) throws {
        guard let data = key.data(using: .utf8) else {
            throw SubscriptionError.verificationFailed(
                NSError(domain: "KeychainService", code: -1, userInfo: [NSLocalizedDescriptionKey: "Failed to encode license key as UTF-8"])
            )
        }
        try saveToKeychain(data: data, forKey: "licenseKey")
    }

    func getLicenseKey() -> String? {
        guard let data = getFromKeychain(forKey: "licenseKey") else { return nil }
        return String(data: data, encoding: .utf8)
    }

    func deleteLicenseKey() throws {
        try deleteFromKeychain(forKey: "licenseKey")
    }

    // MARK: - Trial Flag (Keychain backup)

    func setTrialUsedFlag(_ used: Bool) {
        let data = Data(used ? [1] : [0])
        try? saveToKeychain(data: data, forKey: "trialUsed")
    }

    func getTrialUsedFlag() -> Bool {
        guard let data = getFromKeychain(forKey: "trialUsed"),
              let byte = data.first else { return false }
        return byte == 1
    }

    // MARK: - Daily Count (Keychain backup with HMAC)

    private static let hmacKeyData = Data([0x73, 0x65, 0x72, 0x65, 0x6e, 0x61, 0x2d, 0x68, 0x6d, 0x61, 0x63]) // "serena-hmac"

    /// Save daily count with integrity check
    func saveDailyCount(_ count: Int, date: String) {
        let payload = "\(date):\(count)"
        let hmac = Self.computeHMAC(payload)
        let record = "\(payload)|\(hmac)"
        guard let data = record.data(using: .utf8) else { return }
        try? saveToKeychain(data: data, forKey: "dailyToolCount")
    }

    /// Load daily count with integrity verification. Returns (count, date) or nil if tampered.
    func loadDailyCount() -> (count: Int, date: String)? {
        guard let data = getFromKeychain(forKey: "dailyToolCount"),
              let record = String(data: data, encoding: .utf8) else { return nil }

        let parts = record.split(separator: "|")
        guard parts.count == 2 else { return nil }

        let payload = String(parts[0])
        let storedHMAC = String(parts[1])

        // Verify HMAC
        guard Self.computeHMAC(payload) == storedHMAC else { return nil }

        let payloadParts = payload.split(separator: ":")
        guard payloadParts.count == 2,
              let count = Int(payloadParts[1]) else { return nil }

        return (count: count, date: String(payloadParts[0]))
    }

    /// HMAC-SHA256 integrity check for daily count tamper detection
    private static func computeHMAC(_ input: String) -> String {
        let key = SymmetricKey(data: hmacKeyData)
        let inputData = Data(input.utf8)
        let mac = HMAC<SHA256>.authenticationCode(for: inputData, using: key)
        return Data(mac).map { String(format: "%02x", $0) }.joined()
    }

    // MARK: - Message Timestamps (Keychain backup with HMAC)

    /// Save message timestamps with HMAC integrity check
    func saveMessageTimestamps(_ timestamps: [TimeInterval]) {
        // Encode as comma-separated epoch doubles
        let payload = timestamps.map { String($0) }.joined(separator: ",")
        let hmac = Self.computeHMAC(payload)
        let record = "\(payload)|\(hmac)"
        guard let data = record.data(using: .utf8) else { return }
        try? saveToKeychain(data: data, forKey: "messageTimestamps")
    }

    /// Load message timestamps with HMAC verification. Returns nil if tampered.
    func loadMessageTimestamps() -> [TimeInterval]? {
        guard let data = getFromKeychain(forKey: "messageTimestamps"),
              let record = String(data: data, encoding: .utf8) else { return nil }

        let parts = record.split(separator: "|")
        guard parts.count == 2 else { return nil }

        let payload = String(parts[0])
        let storedHMAC = String(parts[1])

        // Verify HMAC
        guard Self.computeHMAC(payload) == storedHMAC else {
            // Tampered — return nil (treated as empty, user gets fresh window)
            return nil
        }

        // Empty payload means no timestamps yet
        if payload.isEmpty { return [] }

        let timestamps = payload.split(separator: ",").compactMap { TimeInterval($0) }
        return timestamps
    }

    func saveSubscriptionStatus(_ status: SubscriptionStatus) throws {
        let data = try JSONEncoder().encode(status)
        try saveToKeychain(data: data, forKey: "subscriptionStatus")
    }

    func getSubscriptionStatus() -> SubscriptionStatus? {
        guard let data = getFromKeychain(forKey: "subscriptionStatus") else { return nil }
        return try? JSONDecoder().decode(SubscriptionStatus.self, from: data)
    }

    private func saveToKeychain(data: Data, forKey key: String) throws {
        let query: [String: Any] = [
            kSecClass as String: kSecClassGenericPassword,
            kSecAttrService as String: serviceName,
            kSecAttrAccount as String: key,
            kSecValueData as String: data
        ]

        // Delete existing item
        SecItemDelete(query as CFDictionary)

        // Add new item
        let status = SecItemAdd(query as CFDictionary, nil)
        guard status == errSecSuccess else {
            throw SubscriptionError.verificationFailed(
                NSError(domain: "Keychain", code: Int(status), userInfo: nil)
            )
        }
    }

    private func getFromKeychain(forKey key: String) -> Data? {
        let query: [String: Any] = [
            kSecClass as String: kSecClassGenericPassword,
            kSecAttrService as String: serviceName,
            kSecAttrAccount as String: key,
            kSecReturnData as String: true
        ]

        var result: AnyObject?
        let status = SecItemCopyMatching(query as CFDictionary, &result)

        guard status == errSecSuccess,
              let data = result as? Data else {
            return nil
        }

        return data
    }

    private func deleteFromKeychain(forKey key: String) throws {
        let query: [String: Any] = [
            kSecClass as String: kSecClassGenericPassword,
            kSecAttrService as String: serviceName,
            kSecAttrAccount as String: key
        ]

        let status = SecItemDelete(query as CFDictionary)
        guard status == errSecSuccess || status == errSecItemNotFound else {
            throw SubscriptionError.verificationFailed(
                NSError(domain: "Keychain", code: Int(status), userInfo: nil)
            )
        }
    }
}

// MARK: - API Client

/// Client for communicating with Serena license server
public class SubscriptionAPIClient {
    private let baseURL: URL

    /// Date decoder that handles ISO 8601 with or without timezone suffix.
    /// Python's datetime.isoformat() omits timezone for naive datetimes,
    /// but Swift's .iso8601 requires it. This handles both cases.
    private static func makeDateDecoder() -> JSONDecoder {
        let decoder = JSONDecoder()
        let iso8601Full = ISO8601DateFormatter()
        iso8601Full.formatOptions = [.withInternetDateTime, .withFractionalSeconds]
        let iso8601NoFrac = ISO8601DateFormatter()
        iso8601NoFrac.formatOptions = [.withInternetDateTime]

        decoder.dateDecodingStrategy = .custom { decoder in
            let container = try decoder.singleValueContainer()
            let string = try container.decode(String.self)

            // Try standard ISO 8601 first (with timezone)
            if let date = iso8601Full.date(from: string) { return date }
            if let date = iso8601NoFrac.date(from: string) { return date }

            // Server may omit timezone — append Z and retry
            let withZ = string + "Z"
            if let date = iso8601Full.date(from: withZ) { return date }
            if let date = iso8601NoFrac.date(from: withZ) { return date }

            throw DecodingError.dataCorruptedError(in: container, debugDescription: "Cannot decode date: \(string)")
        }
        return decoder
    }

    init(baseURL: String = "https://web-production-95ba1.up.railway.app") {
        // Use environment variable override if present (for testing)
        let defaultURL = URL(string: baseURL) ?? URL(string: "https://web-production-95ba1.up.railway.app")!
        if let envURL = ProcessInfo.processInfo.environment["SERENA_API_URL"],
           let envParsedURL = URL(string: envURL) {
            self.baseURL = envParsedURL
        } else {
            self.baseURL = defaultURL
        }
    }

    struct VerifyResponse: Codable {
        let tier: SubscriptionTier
        let expiresAt: Date
        let gracePeriodEndsAt: Date?
        let isInGracePeriod: Bool
    }

    struct ActivateResponse: Codable {
        let tier: SubscriptionTier
        let expiresAt: Date
        let gracePeriodEndsAt: Date?
        let isInGracePeriod: Bool
    }

    func verify(licenseKey: String, deviceId: String, appVersion: String) async throws -> VerifyResponse {
        var request = URLRequest(url: baseURL.appendingPathComponent("/api/v1/license/verify"))
        request.httpMethod = "POST"
        request.setValue("application/json", forHTTPHeaderField: "Content-Type")

        let body = [
            "license_key": licenseKey,
            "device_id": deviceId,
            "app_version": appVersion
        ]
        request.httpBody = try JSONEncoder().encode(body)

        let (data, response) = try await URLSession.shared.data(for: request)

        guard let httpResponse = response as? HTTPURLResponse else {
            throw SubscriptionError.networkUnavailable
        }

        guard (200...299).contains(httpResponse.statusCode) else {
            throw SubscriptionError.serverError(httpResponse.statusCode)
        }

        return try Self.makeDateDecoder().decode(VerifyResponse.self, from: data)
    }

    func activate(licenseKey: String, deviceId: String, deviceName: String) async throws -> ActivateResponse {
        var request = URLRequest(url: baseURL.appendingPathComponent("/api/v1/license/activate"))
        request.httpMethod = "POST"
        request.setValue("application/json", forHTTPHeaderField: "Content-Type")

        let body = [
            "license_key": licenseKey,
            "device_id": deviceId,
            "device_name": deviceName
        ]
        request.httpBody = try JSONEncoder().encode(body)

        let (data, response) = try await URLSession.shared.data(for: request)

        guard let httpResponse = response as? HTTPURLResponse else {
            throw SubscriptionError.networkUnavailable
        }

        guard (200...299).contains(httpResponse.statusCode) else {
            if httpResponse.statusCode == 403 {
                throw SubscriptionError.deviceLimitExceeded
            }
            throw SubscriptionError.serverError(httpResponse.statusCode)
        }

        return try Self.makeDateDecoder().decode(ActivateResponse.self, from: data)
    }

    func deactivate(licenseKey: String, deviceId: String) async throws {
        var request = URLRequest(url: baseURL.appendingPathComponent("/api/v1/license/deactivate"))
        request.httpMethod = "POST"
        request.setValue("application/json", forHTTPHeaderField: "Content-Type")

        let body = [
            "license_key": licenseKey,
            "device_id": deviceId
        ]
        request.httpBody = try JSONEncoder().encode(body)

        let (_, response) = try await URLSession.shared.data(for: request)

        guard let httpResponse = response as? HTTPURLResponse else {
            throw SubscriptionError.networkUnavailable
        }

        guard (200...299).contains(httpResponse.statusCode) else {
            throw SubscriptionError.serverError(httpResponse.statusCode)
        }
    }

    struct CustomerPortalResponse: Codable {
        let url: String
        let status: String
    }

    /// Get Stripe Customer Portal URL for subscription management
    func getCustomerPortalURL(deviceId: String) async throws -> URL {
        var request = URLRequest(url: baseURL.appendingPathComponent("/api/customer-portal"))
        request.httpMethod = "POST"
        request.setValue("application/json", forHTTPHeaderField: "Content-Type")

        let body = ["device_id": deviceId]
        request.httpBody = try JSONEncoder().encode(body)

        let (data, response) = try await URLSession.shared.data(for: request)

        guard let httpResponse = response as? HTTPURLResponse else {
            throw SubscriptionError.networkUnavailable
        }

        guard (200...299).contains(httpResponse.statusCode) else {
            // Parse error message if available
            if let errorJson = try? JSONDecoder().decode([String: String].self, from: data),
               let errorMsg = errorJson["error"] {
                throw SubscriptionError.verificationFailed(
                    NSError(domain: "CustomerPortal", code: httpResponse.statusCode,
                            userInfo: [NSLocalizedDescriptionKey: errorMsg])
                )
            }
            throw SubscriptionError.serverError(httpResponse.statusCode)
        }

        let portalResponse = try JSONDecoder().decode(CustomerPortalResponse.self, from: data)

        guard let portalURL = URL(string: portalResponse.url) else {
            throw SubscriptionError.verificationFailed(
                NSError(domain: "CustomerPortal", code: -1,
                        userInfo: [NSLocalizedDescriptionKey: "Invalid portal URL returned"])
            )
        }

        return portalURL
    }
}

// MARK: - License Status

public enum LicenseStatus: String {
    case none = "No license"
    case valid = "Active"
    case invalid = "Invalid"
    case expired = "Expired"

    public var color: String {
        switch self {
        case .none: return "secondary"
        case .valid: return "green"
        case .invalid: return "red"
        case .expired: return "orange"
        }
    }
}

// MARK: - Pro Features Enum

public enum ProFeature: String, CaseIterable {
    case unlimitedHistory = "Unlimited History"
    case advancedPersonalization = "Advanced Personalization"
    case priorityRTAI = "Priority Processing"

    public var icon: String {
        switch self {
        case .unlimitedHistory: return "clock.fill"
        case .advancedPersonalization: return "sparkles"
        case .priorityRTAI: return "bolt.fill"
        }
    }

    public var description: String {
        switch self {
        case .unlimitedHistory:
            return "Access all your conversations without time limits"
        case .advancedPersonalization:
            return "Custom instructions and response styles"
        case .priorityRTAI:
            return "Faster AI responses with RTAI"
        }
    }
}
