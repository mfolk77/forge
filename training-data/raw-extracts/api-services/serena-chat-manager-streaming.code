    // MARK: - Idle-Based Learning (Private)

    /// Queue a message for later learning (when idle)
    /// Also runs heuristic pattern detection in real-time (no LLM, no blocking).
    private func queueMessageForLearning(_ message: Message) {
        pendingLearningMessages.append(message)
        resetLearningIdleTimer()
        logger.info("🧠 Queued message for learning (pending: \(self.pendingLearningMessages.count))")

        // Real-time heuristic pattern detection (System 1 primary path)
        if FeatureFlags.learningCoordinatorEnabled && message.role == .user {
            Task.detached { [weak self] in
                guard let self else { return }
                let patterns = await self.heuristicPatternDetector.analyzeMessage(
                    id: message.id.uuidString,
                    content: message.content,
                    timestamp: message.timestamp
                )
                if !patterns.isEmpty {
                    self.logger.info("🧠 Heuristic detected \(patterns.count) pattern(s) in real-time")
                    // Feed patterns into MitosisManager for clustering
                    if FeatureFlags.mitosisClusteringEnabled {
                        for pattern in patterns {
                            await MitosisManager.shared.recordQuery(
                                topic: pattern.topic,
                                keywords: pattern.keywords,
                                messageID: message.id.uuidString
                            )
                        }
                    }
                }
            }
        }
    }

    // MARK: - Inline Fact Extraction (from model response)

    /// Extract and store personal facts from the model's <serena_facts> block.
    /// The model learns during its natural response — no separate inference needed.
    /// Facts are embedded in the response via system prompt instructions.
    private func extractAndStoreInlineFacts(from response: String) {
        guard let startRange = response.range(of: "<serena_facts>"),
              let endRange = response.range(of: "</serena_facts>") else {
            SessionLogger.shared.noInlineFacts()
            return // No facts block — model didn't detect personal facts
        }

        let jsonStr = String(response[startRange.upperBound..<endRange.lowerBound])
            .trimmingCharacters(in: .whitespacesAndNewlines)

        SessionLogger.shared.inlineFactsDetected(raw: jsonStr)
        let facts = parseInlineFacts(jsonStr)
        guard !facts.isEmpty else { return }

        logger.info("🧠 Model extracted \(facts.count) inline fact(s)")

        Task.detached(priority: .utility) { [weak self, facts] in
            guard let self else { return }
            for (key, value) in facts {
                await UserFTAIManager.shared.addFact(
                    key: key, value: value,
                    category: .personal, priority: 10
                )
                self.logger.info("💾 Inline fact stored: \(key) = \(value)")
                SessionLogger.shared.factStored(key: key, value: value)
            }

            // Track for contradiction detection on next message
            await MainActor.run {
                self.pendingFactConfirmations = facts.map {
                    ExtractedFact(fact: "\($0.key): \($0.value)", category: .personal, priority: 10)
                }
            }

            await AnalyticsManager.shared.track("memory_inline_extraction", value: "\(facts.count)")
        }
    }

    /// Parse JSON array of {key, value} objects from inline facts block
    private func parseInlineFacts(_ jsonStr: String) -> [(key: String, value: String)] {
        guard let startIdx = jsonStr.firstIndex(of: "["),
              let endIdx = jsonStr.lastIndex(of: "]") else {
            return []
        }

        let arrayStr = String(jsonStr[startIdx...endIdx])
        guard let data = arrayStr.data(using: .utf8) else { return [] }

        do {
            guard let array = try JSONSerialization.jsonObject(with: data) as? [[String: Any]] else {
                return []
            }

            return array.compactMap { dict in
                guard let key = dict["key"] as? String,
                      let value = dict["value"] as? String,
                      !key.isEmpty, !value.isEmpty else { return nil }
                // Security: strip null bytes, limit length, reject injection payloads
                let cleanKey = key.replacingOccurrences(of: "\0", with: "").prefix(100)
                let cleanValue = value.replacingOccurrences(of: "\0", with: "").prefix(500)
                guard !cleanKey.contains("@tool_call"),
                      !cleanValue.contains("@tool_call") else { return nil }
                // Filter non-personal keys: model sometimes tags topics/interests as "facts"
                let lowerKey = cleanKey.lowercased()
                let nonPersonalKeys = [
                    "interest", "topic", "question", "query", "context", "subject",
                    "research", "search", "request", "task", "asked about",
                    "looking for", "wants to know", "curious about"
                ]
                guard !nonPersonalKeys.contains(where: { lowerKey.contains($0) }) else {
                    self.logger.info("🧠 Filtered non-personal fact key: \(cleanKey)")
                    SessionLogger.shared.log("FACTS", "REJECTED non-personal key: \(cleanKey) = \(cleanValue.prefix(60))")
                    return nil
                }
                return (key: String(cleanKey), value: String(cleanValue))
            }
        } catch {
            logger.debug("🧠 Failed to parse inline facts JSON: \(error.localizedDescription)")
            return []
        }
    }

    /// Reset the idle timer - called after each user interaction.
    /// Uses Task.detached to avoid MainActor/RunLoop contention (original Timer caused CPU freeze Dec 2025).
    private func resetLearningIdleTimer() {
        guard FeatureFlags.learningCoordinatorEnabled else { return }

        // Cancel previous idle task
        learningIdleTask?.cancel()

        let interval = learningIdleInterval

        // Detached task avoids MainActor run loop — safe from CPU freeze
        learningIdleTask = Task.detached(priority: .utility) { [weak self] in
            try? await Task.sleep(nanoseconds: UInt64(interval * 1_000_000_000))

            guard !Task.isCancelled else { return }

            await self?.processQueuedLearningMessages()
        }
    }

    /// Process queued messages when idle (no user activity for 30+ seconds)
    private func processQueuedLearningMessages() async {
        guard !pendingLearningMessages.isEmpty else { return }
        guard let coordinator = learningCoordinator else { return }

        // Don't process if we're currently handling a user request
        if isProcessing {
            logger.debug("🧠 Skipping learning: user request in progress")
            resetLearningIdleTimer() // Try again later
            return
        }

        let messages = pendingLearningMessages
        pendingLearningMessages.removeAll()

        logger.info("🧠 Processing \(messages.count) queued messages for learning (idle trigger)")

        // Track the learning task so it can be cancelled when user sends a message
        learningProcessingTask = Task.detached(priority: .utility) { [weak self] in
            for message in messages {
                // Check cancellation between each message — user inference takes priority
                guard !Task.isCancelled else {
                    await MainActor.run {
                        self?.logger.info("🧠 Learning cancelled — user inference takes priority")
                    }
                    return
                }
                _ = await coordinator.processMessage(message)
            }

            // Update statistics on MainActor
            await MainActor.run { [weak self] in
                Task {
                    self?.learningStatistics = await coordinator.getStatistics()
                }
            }
        }

        // Wait for completion (or cancellation)
        await learningProcessingTask?.value
        learningProcessingTask = nil
    }

