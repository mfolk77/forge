    @discardableResult
    public func runLearningPipeline() async -> Int {
        guard let coordinator = learningCoordinator else {
            logger.warning("🧠 Learning coordinator not available")
            return 0
        }

        logger.info("🧠 Manually triggering learning pipeline...")
        let entries = await coordinator.runLearningPipeline()

        // Update published statistics
        learningStatistics = await coordinator.getStatistics()

        logger.info("🧠 Learning pipeline complete: \(entries.count) entries created")
        return entries.count
    }

    /// Teach content directly — bypasses all thresholds.
    /// Queues LLM extraction after current response to avoid MLX concurrency.
    /// - Parameter content: The content to teach (press release, article, long text, etc.)
    /// - Returns: Number of new knowledge entries created
    @discardableResult
    public func teachDirectly(content: String) async -> Int {
        guard let coordinator = learningCoordinator else {
            logger.warning("🧠 Learning coordinator not available for direct teaching")
            return 0
        }

        logger.info("🧠 Direct teaching: \(content.count) chars")
        let entries = await coordinator.teachDirectly(content: content)

        // Update published statistics
        learningStatistics = await coordinator.getStatistics()

        logger.info("🧠 Direct teaching complete: \(entries.count) entries created")
