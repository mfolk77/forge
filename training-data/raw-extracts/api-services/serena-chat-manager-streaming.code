    /// Reset domain expansion system state
    public func resetDomainExpansion() async {
        guard let coordinator = domainExpansionCoordinator else { return }
        await coordinator.reset()
        domainExpansionStatistics = await coordinator.getStatistics()
        logger.info("🌐 Domain expansion system reset")
    }

    /// Research a specific topic on-demand
    /// - Parameter topic: The topic to research
    /// - Returns: Created domain knowledge or nil
    public func researchTopic(_ topic: String) async -> DomainKnowledge? {
        guard let coordinator = domainExpansionCoordinator else {
            logger.warning("🌐 Domain expansion coordinator not available")
            return nil
        }

        logger.info("🌐 Researching topic: \(topic)")
        let knowledge = await coordinator.researchTopic(topic)

        // Update statistics
        domainExpansionStatistics = await coordinator.getStatistics()

        return knowledge
    }

    // MARK: - Debug & Admin Commands

    /// Handle debug/admin commands that start with "/" - returns true if handled
    /// Admin commands (password-protected) available in all builds
    /// Basic debug commands only in DEBUG builds
    private func handleDebugCommand(_ text: String) async -> Bool {
        let command = text.trimmingCharacters(in: .whitespacesAndNewlines)

        // First, check AdminDiagnosticSuite for password-protected commands (all builds)
        let (handled, result) = await AdminDiagnosticSuite.shared.handleCommand(command)
        if handled {
            if let result = result {
                addDiagnosticResult(result)
            }
            return true
        }

        #if DEBUG
        // Fall through to basic debug commands (available without admin in DEBUG builds)
        let lowerCommand = command.lowercased()

        // /diagnose - Run MLXEngine deadlock diagnostics
        if lowerCommand == "/diagnose" || lowerCommand == "/diag" {
            await runDeadlockDiagnostic()
            return true
        }

        // /memory - Check memory stats
        if lowerCommand == "/memory" || lowerCommand == "/mem" {
            await showMemoryStats()
            return true
        }

        // /stress - Run rapid-fire stress test
        if lowerCommand == "/stress" {
            await runStressTest()
            return true
        }

        // /help-debug - Show available debug commands
        if lowerCommand == "/help-debug" || lowerCommand == "/debug" {
            showDebugHelp()
            return true
        }
        #endif

        return false
    }

    #if DEBUG
    /// Show debug command help
    private func showDebugHelp() {
        let helpText = """
        === DEBUG COMMANDS ===

        Available in DEBUG builds:
          /diagnose   - Run streaming deadlock test
          /stress     - Run rapid-fire stress test
          /memory     - Show memory statistics
          /help-debug - Show this help

        Admin Mode (password protected):
          /admin <password>  - Enter admin mode
          /help-admin        - Show admin commands

        Admin commands unlock additional tests:
          /full, /perf, /rtai, /tools, /tca, /status
        """
        addDiagnosticResult(helpText)
    }
    #endif

    #if DEBUG
    /// Run MLXEngine deadlock diagnostic
    private func runDeadlockDiagnostic() async {
        logger.info("🔬 Starting deadlock diagnostic...")

        // Create a system message to show we're running diagnostics
        guard var conversation = currentConversation else {
            createNewConversation()
            guard var _ = currentConversation else { return }
            return
        }

        let systemMessage = Message(content: "🔬 Running MLXEngine deadlock diagnostic...", role: .assistant)
        conversation.addMessage(systemMessage)
        currentConversation = conversation

        // Run the diagnostic
        guard let engine = aiEngine as? MixtralEngine else {
            addDiagnosticResult("❌ MixtralEngine not available")
            return
        }

        var results: [String] = []
        results.append("=== DEADLOCK DIAGNOSTIC ===")
        results.append("Testing MainActor + streaming interaction\n")

        // Test 1: Basic streaming
        results.append("--- Test 1: Basic Streaming ---")
        let startTime = Date()
        var tokenCount = 0

        do {
            let stream = try await engine.generateStreamingResponse(
                for: "Say hello briefly",
                context: []
            )

            for await _ in stream {
                tokenCount += 1
                if tokenCount >= 20 {
                    break // Quick test
                }
            }

            let duration = Date().timeIntervalSince(startTime)
            results.append("✅ Basic streaming: \(tokenCount) tokens in \(String(format: "%.2f", duration))s")

        } catch {
            results.append("❌ Basic streaming failed: \(error.localizedDescription)")
        }

        // Test 2: Sequential requests (2 quick ones)
        results.append("\n--- Test 2: Sequential Requests ---")
        for i in 1...2 {
            let seqStart = Date()
            var seqTokens = 0

            do {
                let stream = try await engine.generateStreamingResponse(
                    for: "Request \(i): Hi",
                    context: []
                )

                for await _ in stream {
                    seqTokens += 1
                    if seqTokens >= 10 { break }
                }

                let seqDuration = Date().timeIntervalSince(seqStart)
                results.append("✅ Request \(i): \(seqTokens) tokens in \(String(format: "%.2f", seqDuration))s")

            } catch {
                results.append("❌ Request \(i) failed: \(error.localizedDescription)")
            }
        }

        // Summary
        results.append("\n=== DIAGNOSTIC COMPLETE ===")
        if tokenCount > 0 {
            results.append("✅ NO DEADLOCK DETECTED - Streaming works correctly")
        } else {
            results.append("⚠️ POTENTIAL ISSUE - No tokens received")
        }

        addDiagnosticResult(results.joined(separator: "\n"))
    }

    /// Show memory statistics
    private func showMemoryStats() async {
        logger.info("📊 Checking memory stats...")

        guard let engine = aiEngine as? MixtralEngine else {
            addDiagnosticResult("❌ MixtralEngine not available")
            return
        }

        let stats = await engine.getMemoryStats()
        let result = """
        === MEMORY STATS ===
        Total Usage: \(ByteCountFormatter.string(fromByteCount: stats.totalMemoryUsage, countStyle: .memory))
        Model Usage: \(ByteCountFormatter.string(fromByteCount: stats.modelMemoryUsage, countStyle: .memory))
        Cache Usage: \(ByteCountFormatter.string(fromByteCount: stats.cacheMemoryUsage, countStyle: .memory))
        Available: \(ByteCountFormatter.string(fromByteCount: stats.availableMemory, countStyle: .memory))
        Pressure: \(stats.memoryPressureLevel)
        """

        addDiagnosticResult(result)
    }

    /// Run rapid-fire stress test
    private func runStressTest() async {
        logger.info("💥 Starting stress test...")

        guard let engine = aiEngine as? MixtralEngine else {
            addDiagnosticResult("❌ MixtralEngine not available")
            return
        }

        var results: [String] = []
        results.append("=== STRESS TEST (5 rapid requests) ===")

        var successCount = 0
        for i in 1...5 {
            let start = Date()
            var tokens = 0

            do {
                let stream = try await engine.generateStreamingResponse(
                    for: "Quick \(i)",
                    context: []
                )

                for await _ in stream {
                    tokens += 1
                    if tokens >= 5 { break }
                }

                let duration = Date().timeIntervalSince(start)
                results.append("✅ Request \(i): \(tokens) tokens in \(String(format: "%.2f", duration))s")
                successCount += 1

            } catch {
                results.append("❌ Request \(i): \(error.localizedDescription)")
            }

            // Minimal delay
            try? await Task.sleep(nanoseconds: 50_000_000) // 0.05s
        }

        results.append("\nSuccess rate: \(successCount)/5 (\(successCount * 20)%)")
        addDiagnosticResult(results.joined(separator: "\n"))
    }
    #endif

    /// Add diagnostic result as assistant message (available in all builds for admin commands)
    private func addDiagnosticResult(_ result: String) {
        guard var conversation = currentConversation else { return }

        let message = Message(content: result, role: .assistant)
        conversation.addMessage(message)
        currentConversation = conversation
        updateConversationInArray(conversation)

        // Save asynchronously
        Task {
            try? await dataStore.saveConversation(conversation)
        }
    }

    // MARK: - Private Helpers

    /// Strip plain-text thinking/reasoning that Qwen 3.5 outputs without <think> tags.
    /// The model leaks reasoning in multiple formats:
    ///   1. "Thinking Process:\n1. **Analyze..."
    ///   2. "Okay, let me start by understanding..."
    ///   3. "Wait, but according to the instructions..."
    /// All share a common signal: they reference internal system details (system prompt,
    /// remembered facts, RTAI, instructions) that should NEVER appear in user output.
    static func stripPlainTextThinking(_ text: String) -> String {
        let trimmed = text.trimmingCharacters(in: .whitespacesAndNewlines)
        guard !trimmed.isEmpty else { return text }

        // SIGNAL 1: Contains references to internal system details
        // A proper response NEVER mentions these — if present, reasoning leaked
        let internalLeakSignals = [
            "system prompt", "system instruction", "system message",
            "remembered facts", "rtai library", "rtai",
            "according to the instructions", "the instructions say",
            "analyze the request", "analyze system",
            "thinking process", "/no_think",
            "as an llm", "as a model",
            "prompt context", "prompt provided"
        ]

        let lower = trimmed.lowercased()
        let hasInternalLeak = internalLeakSignals.contains { lower.contains($0) }

        // SIGNAL 2: Starts with reasoning preamble patterns
        let reasoningStarters = [
            "okay, let me", "ok, let me", "let me start by",
            "let me think", "let me analyze", "let me understand",
            "first, i need to", "first, let me",
            "i need to analyze", "i need to understand",
            "thinking process"
        ]
        let startsWithReasoning = reasoningStarters.contains { lower.hasPrefix($0) }

        // Only strip if we have strong evidence of reasoning leak
        guard hasInternalLeak || (startsWithReasoning && trimmed.count > 200) else {
            return text
        }

        // Strategy: Find the actual answer buried after the reasoning.
        // The model typically puts reasoning first, then the real answer as the last
        // paragraph(s) that don't contain internal references.

        // Split into paragraphs (double newline separated)
        let paragraphs = trimmed.components(separatedBy: "\n\n")
            .map { $0.trimmingCharacters(in: .whitespacesAndNewlines) }
            .filter { !$0.isEmpty }

        // If only one paragraph, try line-based splitting
        if paragraphs.count <= 1 {
            return stripByLines(trimmed, internalLeakSignals: internalLeakSignals)
        }

        // Find the last paragraph(s) that don't contain internal leak signals
        // Work backwards from the end — the answer is usually at the bottom
        var answerParagraphs: [String] = []
        for paragraph in paragraphs.reversed() {
            let paraLower = paragraph.lowercased()
            let isReasoning = internalLeakSignals.contains { paraLower.contains($0) }
                || paraLower.hasPrefix("wait,")
                || paraLower.hasPrefix("wait ")
                || paraLower.hasPrefix("okay, let me")
                || paraLower.hasPrefix("ok, let me")
                || paraLower.hasPrefix("let me ")
                || paraLower.contains("**analyze")
                || paraLower.contains("**step")
                || (paraLower.first?.isNumber == true && paraLower.contains("**"))

            if isReasoning {
                break  // Stop collecting — everything above this is reasoning
            }
            answerParagraphs.insert(paragraph, at: 0)
        }

        let answer = answerParagraphs.joined(separator: "\n\n")
            .trimmingCharacters(in: .whitespacesAndNewlines)

        // During streaming, the answer may not exist yet — return empty to hide reasoning
        // The caller (streaming loop) will show the isThinking indicator instead
        // Once the full response is in, the answer will be at the end
        return answer
    }

    /// Fallback: strip reasoning by lines when paragraph splitting doesn't work
    private static func stripByLines(_ text: String, internalLeakSignals: [String]) -> String {
        let lines = text.components(separatedBy: "\n")
        var answerLines: [String] = []

        for line in lines.reversed() {
            let lineLower = line.lowercased().trimmingCharacters(in: .whitespaces)
            let isReasoning = internalLeakSignals.contains { lineLower.contains($0) }
                || lineLower.hasPrefix("wait,")
                || lineLower.hasPrefix("okay, let me")
                || lineLower.hasPrefix("let me start")
                || lineLower.contains("**analyze")
            if isReasoning { break }
            answerLines.insert(line, at: 0)
        }

        let answer = answerLines.joined(separator: "\n")
            .trimmingCharacters(in: .whitespacesAndNewlines)
        return answer
    }

    /// Sanitize AI response to remove JSON artifacts, tool calls, and schemas
    /// This ensures clean text-only output when tool calling is disabled
    /// - Parameter response: The raw AI response
    /// - Returns: Clean text response suitable for display
    private func sanitizeResponse(_ response: String) -> String {
        var clean = response

        // Remove <tool_call>...</tool_call> blocks
        clean = clean.replacingOccurrences(
            of: #"<tool_call>[\s\S]*?</tool_call>"#,
            with: "",
            options: .regularExpression
        )

        // Remove <tools>...</tools> schema blocks (JSON vomit fix)
        clean = clean.replacingOccurrences(
            of: #"<tools>[\s\S]*?</tools>"#,
            with: "",
            options: .regularExpression
        )

        // Remove standalone JSON objects (tool schemas)
        clean = clean.replacingOccurrences(
            of: #"\{[^{}]*"type"\s*:\s*"function"[^{}]*\}"#,
            with: "",
            options: .regularExpression
        )

        // Remove TOOL: lines
        clean = clean.replacingOccurrences(
            of: #"TOOL:[^\n]*\n?"#,
            with: "",
            options: .regularExpression
        )

        // Remove any remaining JSON arrays that look like tool definitions
        clean = clean.replacingOccurrences(
            of: #"\[\s*\{[^]]*"function"[^]]*\}\s*\]"#,
            with: "",
            options: .regularExpression
        )

        // Remove XML-style function calls like <launch_app ... />
        clean = clean.replacingOccurrences(
            of: #"<\w+[^>]*/>"#,
            with: "",
            options: .regularExpression
        )

        // Remove phrases that reference tool usage when tools are disabled
        let toolPhrases = [
            "To open or interact with",
            "you must use the tools",
            "Here's how:",
            "I'll use the",
            "Let me use the",
            "Using the tool"
        ]
        for phrase in toolPhrases {
            clean = clean.replacingOccurrences(of: phrase, with: "", options: .caseInsensitive)
        }

        // Clean up excessive whitespace
        clean = clean.replacingOccurrences(of: #"\n{3,}"#, with: "\n\n", options: .regularExpression)
        clean = clean.trimmingCharacters(in: .whitespacesAndNewlines)

        // If after sanitization the response is too short, provide a helpful message
        if clean.count < 5 {
            return "I understand. Is there anything else I can help you with?"
        }

        return clean
    }

    /// Extract confidence level from AI response
    /// - Parameter response: The AI response text
    /// - Returns: Confidence score between 0.0 and 1.0
    private func extractConfidence(from response: String) -> Double {
        let lowerResponse = response.lowercased()

        // High uncertainty phrases (very low confidence)
        let highUncertaintyPhrases = [
            "i don't know",
            "i'm not sure",
            "i cannot confirm",
            "i don't have information",
            "i'm unable to",
            "i cannot find",
            "unfortunately, i don't",
            "i don't have access to"
        ]

        for phrase in highUncertaintyPhrases {
            if lowerResponse.contains(phrase) {
                return 0.3  // Very low confidence
            }
        }

        // Medium uncertainty phrases
        let mediumUncertaintyPhrases = [
            "unclear",
            "possibly",
            "might be",
            "could be",
            "i think",
            "it seems",
            "appears to be",
            "i believe",
            "not certain"
        ]

        for phrase in mediumUncertaintyPhrases {
            if lowerResponse.contains(phrase) {
                return 0.5  // Medium confidence
            }
        }

        // Check for hedging language
        let hedgingPhrases = [
            "generally",
            "typically",
            "usually",
            "in most cases",
            "it depends"
        ]

        for phrase in hedgingPhrases {
            if lowerResponse.contains(phrase) {
                return 0.7  // Moderate confidence
            }
        }

        // Default: reasonably confident
        return 0.85
    }

    // MARK: - TCA Proactive Follow-ups

    /// Check if user is requesting a follow-up (e.g., "remind me about this in 3 days")
    private func checkForFollowUpRequest(_ message: String) {
        let lower = message.lowercased()

        // Pattern: "follow up in X days" or "check back in X days"
        let patterns = [
            #"follow\s*up\s+(?:on\s+this\s+)?in\s+(\d+)\s+days?"#,
            #"check\s+back\s+in\s+(\d+)\s+days?"#,
            #"remind\s+me\s+(?:about\s+this\s+)?in\s+(\d+)\s+days?"#,
        ]

        for pattern in patterns {
            if let regex = try? NSRegularExpression(pattern: pattern, options: .caseInsensitive),
               let match = regex.firstMatch(in: lower, range: NSRange(lower.startIndex..., in: lower)) {
                // Extract days
                if let daysRange = Range(match.range(at: 1), in: lower),
                   let days = Int(lower[daysRange]) {
                    // Extract topic from conversation context
                    let topic = extractTopicFromConversation()
                    ProactiveScheduler.shared.scheduleFollowUp(topic: topic, inDays: days, context: message)
                    logger.info("📅 Scheduled follow-up in \(days) days for: \(topic)")
                    return
                }
            }
        }
    }

    /// Extract the topic from recent conversation for follow-up context
    private func extractTopicFromConversation() -> String {
        guard let conversation = currentConversation else {
            return "our conversation"
        }

        // Get recent messages
        let recentMessages = conversation.messages.suffix(5)
        let userMessages = recentMessages.filter { $0.role == .user }

        // Use the first substantial user message as the topic
        for message in userMessages {
            let content = message.content.trimmingCharacters(in: .whitespacesAndNewlines)
            if content.count > 10 && content.count < 100 {
                return content
            }
        }

        return "what we discussed"
    }

    // MARK: - TCA Behavioral Categorization

    /// Categorize user message into action type for behavioral learning
    private func categorizeUserAction(_ message: String) -> String {
        let lower = message.lowercased()

        // Weather check — specific category for pattern detection
        if lower.contains("weather") || lower.contains("temperature") || lower.contains("forecast")
            || lower.contains("rain") || lower.contains("sunny") || lower.contains("cold outside") || lower.contains("hot outside") {
            return "weather_check"
        }

        // Briefing/morning
        if lower.contains("morning") || lower.contains("brief") {
            return "morning_briefing"
        }

        // Calendar
        if lower.contains("calendar") || lower.contains("schedule") || lower.contains("meeting") || lower.contains("event") {
            return "calendar_check"
        }

        // Reminders
        if lower.contains("remind") || lower.contains("reminder") {
            return "create_reminder"
        }

        // Notes
        if lower.contains("note") || lower.contains("notes") {
            return "notes_action"
        }

        // Music
        if lower.contains("play") || lower.contains("music") || lower.contains("song") || lower.contains("pause") || lower.contains("stop") {
            return "media_control"
        }

        // Screen/context
        if lower.contains("screen") || lower.contains("looking at") {
            return "screen_context"
        }

        // Web search
        if lower.contains("search") || lower.contains("google") {
            return "web_search"
        }

        // Email
        if lower.contains("email") || lower.contains("mail") {
            return "email_action"
        }

        // App launch — use specific app names for better pattern detection
        if lower.contains("open") || lower.contains("launch") {
            // Detect specific apps for granular TCA patterns
            let appNames = ["safari", "chrome", "firefox", "notes", "calendar", "mail",
                            "music", "spotify", "messages", "slack", "terminal", "finder",
                            "xcode", "vscode", "code"]
            for app in appNames {
                if lower.contains(app) {
                    return "app_launch_\(app)"
                }
            }
            return "app_launch"
        }

        // File operations
        if lower.contains("file") || lower.contains("folder") || lower.contains("document") || lower.contains("~/") {
            return "file_operation"
        }

        // General conversation
        return "conversation"
    }

    // MARK: - Teaching Intent Detection

    /// Detect if a user message is explicit teaching content.
    /// Triggers: long content (200+ chars) with teaching signal words,
    /// or "learn this" / "teach you" / "here's info about" prefixes.
    static func isTeachingIntent(_ message: String) -> Bool {
        let lower = message.lowercased()
        let length = message.count

        // Short messages are never teaching content
        guard length >= 100 else { return false }

        // Explicit teaching signals (any length >= 100)
        let teachingPrefixes = [
            "learn this", "remember this", "here's info",
            "here is info", "teach you", "let me teach",
            "study this", "memorize this", "learn about",
            "here's what i know about", "here is what i know about",
            "save this", "know this"
        ]

        for prefix in teachingPrefixes {
            if lower.hasPrefix(prefix) || lower.contains(prefix) {
                return true
            }
        }

        // Long paste (500+ chars) — likely an article, press release, or reference material
        if length >= 500 {
            return true
        }

        return false
    }
}

