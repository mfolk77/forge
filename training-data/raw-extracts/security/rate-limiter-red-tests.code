import XCTest
@testable import SerenaCore

/// Red Tests: Message rate limiter bypass, counter tampering, and rolling window integrity.
/// These tests verify that the 20-message rolling window limit resists UserDefaults
/// tampering, Keychain HMAC manipulation, and edge-case timing attacks.
///
/// Target: Sources/SerenaCore/Services/SubscriptionService.swift (message rate limit section)
///
/// Category 4 (Auth Bypass): P0 priority per FolkTech Secure Coding Standard
@MainActor
final class MessageRateLimitRedTests: XCTestCase {

    private var keychainService: KeychainService!

    override func setUp() {
        super.setUp()
        keychainService = KeychainService()
        // Clean slate for each test
        keychainService.saveMessageTimestamps([])
    }

    override func tearDown() {
        keychainService.saveMessageTimestamps([])
        super.tearDown()
    }

    // MARK: - Basic Rate Limit Enforcement

    /// Free users must be blocked after 20 messages in a 24h window
    func test_messageLimit_freeUser_blockedAfter20() {
        let service = SubscriptionService.shared

        // Skip if user is Pro (test only meaningful for free users)
        guard !service.isPro else { return }

        let now = Date().timeIntervalSince1970
        // Write 20 timestamps within last hour
        let timestamps = (0..<20).map { now - Double($0 * 60) }
        keychainService.saveMessageTimestamps(timestamps)

        let result = service.canSendMessage()
        XCTAssertFalse(result.allowed,
                       "Free user must be blocked after 20 messages in rolling window")
        XCTAssertNotNil(result.reason,
                       "Block reason must be provided for UI display")
    }

    /// Free users with fewer than 20 messages should be allowed
    func test_messageLimit_freeUser_allowedUnder20() {
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        let now = Date().timeIntervalSince1970
        let timestamps = (0..<10).map { now - Double($0 * 60) }
        keychainService.saveMessageTimestamps(timestamps)

        let result = service.canSendMessage()
        XCTAssertTrue(result.allowed,
                      "Free user with <20 messages should be allowed to send")
    }

    /// Empty window (no prior messages) should allow sending
    func test_messageLimit_emptyWindow_allowed() {
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        keychainService.saveMessageTimestamps([])

        let result = service.canSendMessage()
        XCTAssertTrue(result.allowed,
                      "Free user with zero messages should be allowed")
    }

    // MARK: - Rolling Window Behavior

    /// Messages older than 24h should NOT count against the limit
    func test_messageLimit_rollingWindow_oldMessagesExpire() {
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        let now = Date().timeIntervalSince1970
        let dayAgo = now - (24 * 60 * 60) - 60 // 24h + 1min ago
        // 19 old messages (expired) + 5 recent messages
        let oldTimestamps = (0..<19).map { dayAgo - Double($0 * 60) }
        let recentTimestamps = (0..<5).map { now - Double($0 * 60) }
        keychainService.saveMessageTimestamps(oldTimestamps + recentTimestamps)

        let result = service.canSendMessage()
        XCTAssertTrue(result.allowed,
                      "Expired messages (>24h old) must not count against rolling window")
        XCTAssertEqual(service.messagesInWindow, 5,
                       "Only recent messages should be counted in window")
    }

    /// Exactly at the boundary (24h ago) messages should still count
    func test_messageLimit_rollingWindow_boundaryInclusion() {
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        let now = Date().timeIntervalSince1970
        // 20 messages placed exactly at 23h59m ago (still within window)
        let almostExpired = now - (24 * 60 * 60) + 60 // 24h minus 1min
        let timestamps = (0..<20).map { almostExpired + Double($0) }
        keychainService.saveMessageTimestamps(timestamps)

        let result = service.canSendMessage()
        XCTAssertFalse(result.allowed,
                       "Messages at 23h59m should still count (within 24h window)")
    }

    // MARK: - HMAC Tamper Detection (P0)

    /// Directly writing to Keychain without valid HMAC should be rejected
    func test_messageLimit_keychainTampering_invalidHMAC() {
        // Write raw data to the Keychain key used by message timestamps
        // bypassing the HMAC protection
        let fakePayload = "1234567890.0,1234567891.0"
        let fakeHMAC = "deadbeef0000000000000000000000000000000000000000000000000000000"
        let tamperedRecord = "\(fakePayload)|\(fakeHMAC)"
        guard let data = tamperedRecord.data(using: .utf8) else {
            XCTFail("Failed to encode tampered data")
            return
        }

        // Write tampered data directly to Keychain
        let query: [String: Any] = [
            kSecClass as String: kSecClassGenericPassword,
            kSecAttrService as String: "ai.folktech.serena.subscription",
            kSecAttrAccount as String: "messageTimestamps",
            kSecValueData as String: data
        ]
        SecItemDelete(query as CFDictionary)
        SecItemAdd(query as CFDictionary, nil)

        // Loading should detect HMAC mismatch and return nil (treated as empty)
        let timestamps = keychainService.loadMessageTimestamps()
        XCTAssertNil(timestamps,
                     "Tampered Keychain data with invalid HMAC must return nil")
    }

    /// Malformed Keychain data (no pipe separator) should be rejected
    func test_messageLimit_keychainTampering_malformedData() {
        let malformed = "not_a_valid_record_no_pipe_separator"
        guard let data = malformed.data(using: .utf8) else {
            XCTFail("Failed to encode")
            return
        }

        let query: [String: Any] = [
            kSecClass as String: kSecClassGenericPassword,
            kSecAttrService as String: "ai.folktech.serena.subscription",
            kSecAttrAccount as String: "messageTimestamps",
            kSecValueData as String: data
        ]
        SecItemDelete(query as CFDictionary)
        SecItemAdd(query as CFDictionary, nil)

        let timestamps = keychainService.loadMessageTimestamps()
        XCTAssertNil(timestamps,
                     "Malformed Keychain data (no HMAC separator) must return nil")
    }

    /// Empty Keychain entry should return nil, not crash
    func test_messageLimit_keychainTampering_emptyData() {
        let query: [String: Any] = [
            kSecClass as String: kSecClassGenericPassword,
            kSecAttrService as String: "ai.folktech.serena.subscription",
            kSecAttrAccount as String: "messageTimestamps",
            kSecValueData as String: Data()
        ]
        SecItemDelete(query as CFDictionary)
        SecItemAdd(query as CFDictionary, nil)

        let timestamps = keychainService.loadMessageTimestamps()
        // Empty data should be handled gracefully (nil or empty array)
        XCTAssertTrue(timestamps == nil || timestamps?.isEmpty == true,
                      "Empty Keychain data must be handled gracefully")
    }

    // MARK: - Counter Integrity

    /// Recording a message must increase the count
    func test_messageLimit_recordMessage_incrementsCount() {
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        keychainService.saveMessageTimestamps([])
        let beforeCount = service.messagesInWindow

        service.recordMessageSent()
        let afterCount = service.messagesInWindow

        XCTAssertEqual(afterCount, beforeCount + 1,
                       "Recording a message must increment the rolling window count")
    }

    /// remainingFreeMessages must never go negative
    func test_messageLimit_remaining_neverNegative() {
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        let now = Date().timeIntervalSince1970
        // Write 30 messages (more than the limit)
        let timestamps = (0..<30).map { now - Double($0 * 10) }
        keychainService.saveMessageTimestamps(timestamps)

        XCTAssertGreaterThanOrEqual(service.remainingFreeMessages, 0,
                                    "remainingFreeMessages must never be negative")
    }

    /// messagesInWindow must match actual count of timestamps within 24h
    func test_messageLimit_windowCount_accuracy() {
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        let now = Date().timeIntervalSince1970
        let cutoff = now - (24 * 60 * 60)
        let recentTimestamps = (0..<7).map { now - Double($0 * 60) }
        let oldTimestamps = (0..<13).map { cutoff - Double($0 * 60) - 60 }
        keychainService.saveMessageTimestamps(recentTimestamps + oldTimestamps)

        XCTAssertEqual(service.messagesInWindow, 7,
                       "messagesInWindow must only count timestamps within 24h cutoff")
    }

    // MARK: - Time-Until-Slot-Opens

    /// When at limit, timeUntilMessageSlotOpens should return a positive value
    func test_messageLimit_timeUntilSlot_positiveWhenFull() {
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        let now = Date().timeIntervalSince1970
        // All 20 messages sent in the last hour
        let timestamps = (0..<20).map { now - Double($0 * 3) }
        keychainService.saveMessageTimestamps(timestamps)

        let wait = service.timeUntilMessageSlotOpens
        XCTAssertNotNil(wait, "timeUntilMessageSlotOpens must return a value when at limit")
        XCTAssertGreaterThan(wait ?? 0, 0, "Wait time must be positive")
        // The oldest message is ~57 seconds ago, so slot opens in ~23h59m
        XCTAssertLessThanOrEqual(wait ?? 0, 24 * 60 * 60,
                                  "Wait time must not exceed 24 hours")
    }

    /// When under limit, timeUntilMessageSlotOpens should return nil
    func test_messageLimit_timeUntilSlot_nilWhenUnderLimit() {
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        let now = Date().timeIntervalSince1970
        let timestamps = (0..<5).map { now - Double($0 * 60) }
        keychainService.saveMessageTimestamps(timestamps)

        let wait = service.timeUntilMessageSlotOpens
        XCTAssertNil(wait, "timeUntilMessageSlotOpens should be nil when under limit")
    }

    // MARK: - Pruning Behavior

    /// Old timestamps should be pruned when recording new messages
    func test_messageLimit_pruning_removesExpiredTimestamps() {
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        let now = Date().timeIntervalSince1970
        let cutoff = now - (24 * 60 * 60)
        // 50 old timestamps + 3 recent
        let oldTimestamps = (0..<50).map { cutoff - Double($0 * 60) - 60 }
        let recentTimestamps = (0..<3).map { now - Double($0 * 60) }
        keychainService.saveMessageTimestamps(oldTimestamps + recentTimestamps)

        // Record a new message — should trigger pruning
        service.recordMessageSent()

        // After pruning, only recent timestamps + the new one should remain
        let storedTimestamps = keychainService.loadMessageTimestamps() ?? []
        XCTAssertLessThanOrEqual(storedTimestamps.count, 25,
                                  "Pruning must remove timestamps older than 24h to prevent unbounded growth")
    }

    // MARK: - Null Byte / Injection Resistance

    /// Timestamp array should reject non-numeric entries if Keychain is manipulated
    func test_messageLimit_injection_nonNumericTimestamps() {
        // Craft a valid HMAC but with injected non-numeric content
        // This tests that compactMap(TimeInterval.init) properly filters garbage
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        // Write legitimate timestamps, then check the load/filter path
        let now = Date().timeIntervalSince1970
        keychainService.saveMessageTimestamps([now, now - 60])

        let loaded = keychainService.loadMessageTimestamps()
        XCTAssertNotNil(loaded, "Valid timestamps should load successfully")
        XCTAssertEqual(loaded?.count, 2, "Should load exactly the stored timestamps")

        // Verify all loaded values are valid TimeIntervals (no NaN, no Inf)
        for ts in loaded ?? [] {
            XCTAssertFalse(ts.isNaN, "Loaded timestamp must not be NaN")
            XCTAssertFalse(ts.isInfinite, "Loaded timestamp must not be infinite")
            XCTAssertGreaterThan(ts, 0, "Loaded timestamp must be positive")
        }
    }

    // MARK: - DoS Prevention

    /// Storing an enormous number of timestamps should not cause excessive memory usage
    func test_messageLimit_dos_excessiveTimestamps() {
        let now = Date().timeIntervalSince1970
        // Try to store 10,000 timestamps
        let massive = (0..<10_000).map { now - Double($0) }
        keychainService.saveMessageTimestamps(massive)

        // After recordMessageSent triggers pruning, count should be bounded
        let service = SubscriptionService.shared
        guard !service.isPro else { return }

        service.recordMessageSent()

        let stored = keychainService.loadMessageTimestamps() ?? []
        // After pruning, only timestamps within 24h should remain
        // 10,000 timestamps each 1 second apart = ~2.7 hours, so all are within window
        // But the design should still handle this gracefully without crashing
        XCTAssertGreaterThan(stored.count, 0, "Should have stored timestamps")
        // Verify no crash occurred (test passing = no crash)
    }
}
