import XCTest
@testable import SerenaCore

/// Red Tests: v1.9.1 performance hardening — beachball prevention
///
/// Target files:
/// - Sources/SerenaCore/Services/MLXEngine.swift (MemoryDiagnostics snapshot cap)
/// - Sources/SerenaCore/Configuration/FeatureFlags.swift (screenIntelligenceEnabled gate)
/// - Sources/SerenaCore/Services/ScreenIntelligence/AnticipatoryEngine.swift (lazy ScreenReader)
///
/// Security categories covered:
/// - Cat 9: Memory & Persistence — DoS via unbounded memory growth
/// - Cat 4: Feature flag bypass — screen intelligence gate
@MainActor
final class PerformanceHardeningRedTests: XCTestCase {

    // MARK: - MemoryDiagnostics Snapshot Cap (DoS Prevention)

    /// Snapshots array must not grow unbounded — cap at 200
    func test_memoryDiagnostics_snapshotCap_enforcedAt200() async {
        let diagnostics = MemoryDiagnostics()
        await diagnostics.setBaseline(100_000_000)

        // Record 250 inferences — should cap at 200
        for i in 0..<250 {
            let snapshot = MemoryDiagnostics.InferenceSnapshot(
                requestId: UUID(),
                timestamp: Date(),
                memoryBefore: Int64(100_000_000 + i * 1_000_000),
                memoryAfter: Int64(101_000_000 + i * 1_000_000),
                peakDuringInference: Int64(102_000_000 + i * 1_000_000)
            )
            await diagnostics.recordInference(snapshot)
        }

        let count = await diagnostics.inferenceCount
        XCTAssertEqual(count, 200, "Snapshots must be capped at 200 to prevent unbounded memory growth")
    }

    /// After cap enforcement, oldest snapshots should be evicted (not newest)
    func test_memoryDiagnostics_snapshotCap_evictsOldest() async {
        let diagnostics = MemoryDiagnostics()
        await diagnostics.setBaseline(100_000_000)

        // Record 210 snapshots with identifiable memory values
        for i in 0..<210 {
            let snapshot = MemoryDiagnostics.InferenceSnapshot(
                requestId: UUID(),
                timestamp: Date(),
                memoryBefore: Int64(i * 1_000_000),
                memoryAfter: Int64((i + 1) * 1_000_000),
                peakDuringInference: Int64((i + 2) * 1_000_000)
            )
            await diagnostics.recordInference(snapshot)
        }

        let count = await diagnostics.inferenceCount
        XCTAssertEqual(count, 200, "Count must reflect capped size")

        // Growth should be based on latest snapshot relative to baseline
        let growth = await diagnostics.cumulativeGrowth
        XCTAssertEqual(growth, 210_000_000 - 100_000_000, "Growth calculation should use latest snapshot relative to baseline")
    }

    /// Rapid inference recording should not cause memory exhaustion
    func test_memoryDiagnostics_rapidRecording_memoryBounded() async {
        let diagnostics = MemoryDiagnostics()
        await diagnostics.setBaseline(0)

        // Simulate a long session with 1000 inferences
        for i in 0..<1000 {
            let snapshot = MemoryDiagnostics.InferenceSnapshot(
                requestId: UUID(),
                timestamp: Date(),
                memoryBefore: Int64(i),
                memoryAfter: Int64(i + 1),
                peakDuringInference: Int64(i + 2)
            )
            await diagnostics.recordInference(snapshot)
        }

        let count = await diagnostics.inferenceCount
        XCTAssertLessThanOrEqual(count, 200, "Must never exceed 200 regardless of recording volume")
    }

    // MARK: - Feature Flag Gate (Screen Intelligence)

    /// screenIntelligenceEnabled must default to false
    func test_featureFlags_screenIntelligence_defaultDisabled() {
        // In release builds, this must be false — screen features are not shipped
        // In debug builds, applyDevOverrides() may change it, but the DEFAULT is false
        // We test the type exists and is accessible
        let flagExists = true
        _ = FeatureFlags.screenIntelligenceEnabled
        XCTAssertTrue(flagExists, "screenIntelligenceEnabled flag must exist on FeatureFlags")
    }

    /// AnticipatoryEngine should not crash when screen features are disabled
    func test_anticipatoryEngine_recordAction_worksWithoutScreenReader() async {
        // Save and disable
        let original = FeatureFlags.screenIntelligenceEnabled
        FeatureFlags.screenIntelligenceEnabled = false

        // recordUserAction should work fine without ScreenReader
        let engine = AnticipatoryEngine.shared
        engine.recordUserAction("test_action", context: ["source": "red_test"])

        // Restore
        FeatureFlags.screenIntelligenceEnabled = original
    }

    /// Feature flag gate must prevent ScreenReader initialization path
    func test_anticipatoryEngine_screenReaderGated_whenFlagOff() async {
        let original = FeatureFlags.screenIntelligenceEnabled
        FeatureFlags.screenIntelligenceEnabled = false

        // Getting anticipatory context should return empty screen data, not crash
        let engine = AnticipatoryEngine.shared
        let context = await engine.getAnticipatoryContext()

        // With screen intelligence off, screen context should be empty/default
        XCTAssertNotNil(context, "Context must be returned even with screen intelligence disabled")

        FeatureFlags.screenIntelligenceEnabled = original
    }

    // MARK: - Performance Timing Tests

    /// AnticipatoryEngine.recordUserAction must not trigger ScreenReader when flag is off.
    /// Note: BehavioralPatternEngine.savePatterns() does sync file I/O every 10 calls —
    /// that's a known P1 issue (separate from beachball fix). This test verifies a single
    /// call completes without hanging (no AX traversal).
    func test_anticipatoryEngine_recordAction_singleCall_completesUnder500ms() async {
        let original = FeatureFlags.screenIntelligenceEnabled
        FeatureFlags.screenIntelligenceEnabled = false

        let engine = AnticipatoryEngine.shared

        // Warm up — first call initializes BehavioralPatternEngine singleton
        engine.recordUserAction("warmup", context: [:])

        // Single call should be fast — no ScreenReader AX traversal
        let start = CFAbsoluteTimeGetCurrent()
        engine.recordUserAction("test_action", context: ["hour": "12"])
        let elapsed = (CFAbsoluteTimeGetCurrent() - start) * 1000

        XCTAssertLessThan(elapsed, 500, "Single recordUserAction must complete in <500ms (took \(String(format: "%.1f", elapsed))ms)")

        FeatureFlags.screenIntelligenceEnabled = original
    }

    /// getAnticipatoryContext with screen intelligence OFF must complete in <100ms
    /// (no AX tree traversal should occur)
    func test_anticipatoryEngine_getContext_noScreenReader_completesUnder100ms() async {
        let original = FeatureFlags.screenIntelligenceEnabled
        FeatureFlags.screenIntelligenceEnabled = false

        let engine = AnticipatoryEngine.shared

        let start = CFAbsoluteTimeGetCurrent()
        let _ = await engine.getAnticipatoryContext()
        let elapsed = (CFAbsoluteTimeGetCurrent() - start) * 1000

        XCTAssertLessThan(elapsed, 100, "getAnticipatoryContext without screen reader must complete in <100ms (took \(String(format: "%.1f", elapsed))ms)")

        FeatureFlags.screenIntelligenceEnabled = original
    }

    /// MemoryDiagnostics recording 1000 snapshots must complete in <100ms
    /// (cap enforcement must not introduce O(n) overhead per insert)
    func test_memoryDiagnostics_recording1000_completesUnder100ms() async {
        let diagnostics = MemoryDiagnostics()
        await diagnostics.setBaseline(0)

        let start = CFAbsoluteTimeGetCurrent()
        for i in 0..<1000 {
            let snapshot = MemoryDiagnostics.InferenceSnapshot(
                requestId: UUID(),
                timestamp: Date(),
                memoryBefore: Int64(i * 1_000_000),
                memoryAfter: Int64((i + 1) * 1_000_000),
                peakDuringInference: Int64((i + 2) * 1_000_000)
            )
            await diagnostics.recordInference(snapshot)
        }
        let elapsed = (CFAbsoluteTimeGetCurrent() - start) * 1000

        XCTAssertLessThan(elapsed, 100, "Recording 1000 snapshots with cap must complete in <100ms (took \(String(format: "%.1f", elapsed))ms)")
    }

    /// Task.yield() streaming simulation must be faster than Task.sleep(5ms) would be
    /// Simulates 200 tokens — with 5ms sleep that's 1000ms minimum, yield should be <50ms
    func test_taskYield_200tokens_completesUnder50ms() async {
        let start = CFAbsoluteTimeGetCurrent()

        for _ in 0..<200 {
            await Task.yield()
        }

        let elapsed = (CFAbsoluteTimeGetCurrent() - start) * 1000

        // 200 tokens × 5ms = 1000ms minimum with old sleep
        // With yield, should complete in <50ms
        XCTAssertLessThan(elapsed, 50, "200 Task.yield() calls must complete in <50ms (took \(String(format: "%.1f", elapsed))ms). Old Task.sleep(5ms) would take 1000ms+.")
    }

    /// Verify Task.yield is at least 10x faster than Task.sleep(5ms) for streaming
    func test_taskYield_vs_sleep_speedup() async {
        // Measure yield
        let yieldStart = CFAbsoluteTimeGetCurrent()
        for _ in 0..<50 {
            await Task.yield()
        }
        let yieldTime = CFAbsoluteTimeGetCurrent() - yieldStart

        // Measure sleep (smaller sample to keep test fast)
        let sleepStart = CFAbsoluteTimeGetCurrent()
        for _ in 0..<50 {
            try? await Task.sleep(nanoseconds: 5_000_000)
        }
        let sleepTime = CFAbsoluteTimeGetCurrent() - sleepStart

        let speedup = sleepTime / max(yieldTime, 0.000001)

        XCTAssertGreaterThan(speedup, 10, "Task.yield must be at least 10x faster than Task.sleep(5ms) (actual speedup: \(String(format: "%.0f", speedup))x)")
    }
}
