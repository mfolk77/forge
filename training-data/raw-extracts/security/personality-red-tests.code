import XCTest
@testable import SerenaCore

final class PersonalityRedTests: XCTestCase {

    private let analyzer = ToneAnalyzer.shared

    override func setUp() {
        super.setUp()
        // Reset personality UserDefaults for RelationshipTracker tests
        UserDefaults.standard.removeObject(forKey: "SerenaPersonality.firstLaunchDate")
        UserDefaults.standard.removeObject(forKey: "SerenaPersonality.interactionCount")
    }

    // MARK: - ToneAnalyzer Tests

    // 1. Urgency detection — "asap" triggers urgency > 0.5
    func test_toneAnalyzer_detectsUrgency() {
        let signal = analyzer.analyze("I need this asap please")
        XCTAssertGreaterThan(signal.urgency, 0.5, "Message containing 'asap' should have urgency > 0.5")
    }

    // 2. Frustration detection — "broken" + "doesn't work" triggers frustration > 0.4
    func test_toneAnalyzer_detectsFrustration() {
        let signal = analyzer.analyze("This is broken and doesn't work")
        XCTAssertGreaterThan(signal.frustration, 0.4, "Message with frustrated phrases should have frustration > 0.4")
    }

    // 3. Casual detection — two casual markers triggers casualness > 0.8
    func test_toneAnalyzer_detectsCasualness() {
        let signal = analyzer.analyze("hey lol what's up")
        XCTAssertGreaterThan(signal.casualness, 0.8, "Message with multiple casual markers should have casualness > 0.8")
    }

    // 4. Formal detection — multiple formal markers triggers casualness < 0.2
    func test_toneAnalyzer_detectsFormality() {
        let signal = analyzer.analyze("I would appreciate it if you could kindly assist")
        XCTAssertLessThan(signal.casualness, 0.2, "Message with formal markers should have casualness < 0.2")
    }

    // 5. Warmth detection — gratitude phrases trigger warmth > 0.6
    func test_toneAnalyzer_detectsWarmth() {
        let signal = analyzer.analyze("thanks so much, you're the best!")
        XCTAssertGreaterThan(signal.warmth, 0.6, "Message with warm phrases should have warmth > 0.6")
    }

    // 6. Neutral message — no significant tone dimensions
    func test_toneAnalyzer_neutralMessageIsNotSignificant() {
        let signal = analyzer.analyze("What is the weather in Paris")
        XCTAssertFalse(signal.isSignificant, "Neutral factual question should not be significant")
    }

    // 7. ALL CAPS urgency boost — all-caps message with >2 words triggers urgency > 0.5
    func test_toneAnalyzer_allCapsBoostsUrgency() {
        let signal = analyzer.analyze("HELP ME WITH THIS NOW")
        XCTAssertGreaterThan(signal.urgency, 0.5, "ALL CAPS message with >2 words should have urgency > 0.5")
    }

    // 8. promptHint frustrated — frustrated signal produces hint containing "acknowledgment"
    func test_toneAnalyzer_promptHintForFrustration() {
        let signal = analyzer.analyze("This is broken and doesn't work")
        let hint = analyzer.promptHint(from: signal)
        XCTAssertTrue(hint.contains("acknowledgment"), "Frustrated hint should contain 'acknowledgment', got: \(hint)")
    }

    // 9. promptHint neutral — neutral signal produces empty hint
    func test_toneAnalyzer_promptHintForNeutralIsEmpty() {
        let hint = analyzer.promptHint(from: .neutral)
        XCTAssertEqual(hint, "", "Neutral signal should produce empty prompt hint")
    }

    // 10. promptHint priority — frustration takes precedence over urgency
    func test_toneAnalyzer_promptHintFrustrationTakesPriority() {
        let signal = analyzer.analyze("This is broken and doesn't work, fix it asap")
        let hint = analyzer.promptHint(from: signal)
        XCTAssertTrue(hint.contains("Frustrated"), "When both frustrated and urgent, frustration hint should win, got: \(hint)")
    }

    // MARK: - RelationshipTracker Tests

    // 1. Default stage is .new when UserDefaults are clear
    @MainActor
    func test_relationshipTracker_defaultNewStage() {
        let tracker = RelationshipTracker.shared
        XCTAssertEqual(tracker.stage, .new, "Fresh UserDefaults should yield .new stage")
    }

    // 2. Familiar stage — 10 days + 25 interactions
    @MainActor
    func test_relationshipTracker_familiarStage() {
        let tenDaysAgo = Calendar.current.date(byAdding: .day, value: -10, to: Date())!
        UserDefaults.standard.set(tenDaysAgo, forKey: "SerenaPersonality.firstLaunchDate")
        UserDefaults.standard.set(25, forKey: "SerenaPersonality.interactionCount")
        XCTAssertEqual(RelationshipTracker.shared.stage, .familiar, "10 days + 25 interactions should yield .familiar stage")
    }

    // 3. Companion stage — 35 days + 105 interactions
    @MainActor
    func test_relationshipTracker_companionStage() {
        let thirtyFiveDaysAgo = Calendar.current.date(byAdding: .day, value: -35, to: Date())!
        UserDefaults.standard.set(thirtyFiveDaysAgo, forKey: "SerenaPersonality.firstLaunchDate")
        UserDefaults.standard.set(105, forKey: "SerenaPersonality.interactionCount")
        XCTAssertEqual(RelationshipTracker.shared.stage, .companion, "35 days + 105 interactions should yield .companion stage")
    }

    // 4. recordInteraction increments count
    @MainActor
    func test_relationshipTracker_recordInteractionIncrementsCount() {
        let tracker = RelationshipTracker.shared
        let before = tracker.interactionCount
        tracker.recordInteraction()
        XCTAssertEqual(tracker.interactionCount, before + 1, "recordInteraction() should increment interaction count by 1")
    }

    // 5. promptFragment is empty for .new stage
    @MainActor
    func test_relationshipTracker_promptFragmentEmptyForNew() {
        let tracker = RelationshipTracker.shared
        XCTAssertEqual(tracker.promptFragment, "", "New stage should produce empty promptFragment")
    }

    // 6. promptFragment for .familiar contains "known this user"
    @MainActor
    func test_relationshipTracker_promptFragmentForFamiliar() {
        let tenDaysAgo = Calendar.current.date(byAdding: .day, value: -10, to: Date())!
        UserDefaults.standard.set(tenDaysAgo, forKey: "SerenaPersonality.firstLaunchDate")
        UserDefaults.standard.set(25, forKey: "SerenaPersonality.interactionCount")
        let fragment = RelationshipTracker.shared.promptFragment
        XCTAssertTrue(fragment.contains("known this user"), "Familiar promptFragment should contain 'known this user', got: \(fragment)")
    }

    // 7. promptFragment for .companion contains "trusted companion"
    @MainActor
    func test_relationshipTracker_promptFragmentForCompanion() {
        let thirtyFiveDaysAgo = Calendar.current.date(byAdding: .day, value: -35, to: Date())!
        UserDefaults.standard.set(thirtyFiveDaysAgo, forKey: "SerenaPersonality.firstLaunchDate")
        UserDefaults.standard.set(105, forKey: "SerenaPersonality.interactionCount")
        let fragment = RelationshipTracker.shared.promptFragment
        XCTAssertTrue(fragment.contains("trusted companion"), "Companion promptFragment should contain 'trusted companion', got: \(fragment)")
    }

    // 8. Dual threshold — days alone not enough without interactions
    @MainActor
    func test_relationshipTracker_dualThresholdRequired() {
        let tenDaysAgo = Calendar.current.date(byAdding: .day, value: -10, to: Date())!
        UserDefaults.standard.set(tenDaysAgo, forKey: "SerenaPersonality.firstLaunchDate")
        UserDefaults.standard.set(5, forKey: "SerenaPersonality.interactionCount")
        XCTAssertEqual(RelationshipTracker.shared.stage, .new, "10 days with only 5 interactions should still be .new — both thresholds required")
    }

    // MARK: - ResponseStyle Tests

    // 1. All four cases exist
    func test_responseStyle_allFourCasesExist() {
        XCTAssertEqual(ResponseStyle.allCases.count, 4, "ResponseStyle should have exactly 4 cases")
    }

    // 2. Balanced has empty directive
    func test_responseStyle_balancedHasEmptyDirective() {
        XCTAssertTrue(ResponseStyle.balanced.directive.isEmpty, "Balanced directive should be empty (default — no injection)")
    }

    // 3. Non-balanced cases all have non-empty directives
    func test_responseStyle_nonBalancedHaveDirectives() {
        let nonBalanced = ResponseStyle.allCases.filter { $0 != .balanced }
        for style in nonBalanced {
            XCTAssertFalse(style.directive.isEmpty, "\(style.rawValue) should have a non-empty directive")
        }
    }

    // 4. Codable round-trip — encode then decode each case
    func test_responseStyle_codableRoundTrip() {
        let encoder = JSONEncoder()
        let decoder = JSONDecoder()
        for style in ResponseStyle.allCases {
            let data = try! encoder.encode(style)
            let decoded = try! decoder.decode(ResponseStyle.self, from: data)
            XCTAssertEqual(style, decoded, "\(style.rawValue) should survive JSON round-trip")
        }
    }

    // MARK: - Integration Tests

    // 5. Tone and relationship produce output independently
    @MainActor
    func test_integration_toneAndRelationshipProduceOutputIndependently() {
        // ToneAnalyzer: frustrated message should produce a non-empty hint
        let signal = analyzer.analyze("This is broken and doesn't work")
        let hint = analyzer.promptHint(from: signal)
        XCTAssertFalse(hint.isEmpty, "Frustrated message should produce a non-empty prompt hint")

        // RelationshipTracker: familiar stage should produce a non-empty fragment
        let tenDaysAgo = Calendar.current.date(byAdding: .day, value: -10, to: Date())!
        UserDefaults.standard.set(tenDaysAgo, forKey: "SerenaPersonality.firstLaunchDate")
        UserDefaults.standard.set(25, forKey: "SerenaPersonality.interactionCount")
        let fragment = RelationshipTracker.shared.promptFragment
        XCTAssertFalse(fragment.isEmpty, "Familiar stage should produce a non-empty prompt fragment")
    }

    // 6. Token budget — all directives/hints/fragments stay under 50 words each
    @MainActor
    func test_integration_tokenBudget() {
        let maxWords = 50

        // ResponseStyle directives
        for style in ResponseStyle.allCases {
            let words = style.directive.split(separator: " ").count
            XCTAssertLessThan(words, maxWords, "\(style.rawValue) directive should be under \(maxWords) words, got \(words)")
        }

        // ToneAnalyzer hints for each significant type
        let testMessages: [(String, String)] = [
            ("This is broken and doesn't work", "frustrated"),
            ("I need this asap please", "urgent"),
            ("hey lol what's up", "casual"),
            ("I would appreciate it if you could kindly assist", "formal"),
            ("thanks so much, you're the best!", "warm"),
        ]
        for (message, label) in testMessages {
            let signal = analyzer.analyze(message)
            let hint = analyzer.promptHint(from: signal)
            let words = hint.split(separator: " ").count
            XCTAssertLessThan(words, maxWords, "\(label) hint should be under \(maxWords) words, got \(words)")
        }

        // RelationshipTracker fragments for each stage
        // .new — empty, skip
        // .familiar
        let tenDaysAgo = Calendar.current.date(byAdding: .day, value: -10, to: Date())!
        UserDefaults.standard.set(tenDaysAgo, forKey: "SerenaPersonality.firstLaunchDate")
        UserDefaults.standard.set(25, forKey: "SerenaPersonality.interactionCount")
        let familiarWords = RelationshipTracker.shared.promptFragment.split(separator: " ").count
        XCTAssertLessThan(familiarWords, maxWords, "Familiar fragment should be under \(maxWords) words, got \(familiarWords)")

        // .companion
        let thirtyFiveDaysAgo = Calendar.current.date(byAdding: .day, value: -35, to: Date())!
        UserDefaults.standard.set(thirtyFiveDaysAgo, forKey: "SerenaPersonality.firstLaunchDate")
        UserDefaults.standard.set(105, forKey: "SerenaPersonality.interactionCount")
        let companionWords = RelationshipTracker.shared.promptFragment.split(separator: " ").count
        XCTAssertLessThan(companionWords, maxWords, "Companion fragment should be under \(maxWords) words, got \(companionWords)")
    }

    // 7. Feature flag exists and is accessible
    func test_integration_featureFlagDefaultIsFalse() {
        // In DEBUG, applyDevOverrides() sets personalityEnabled = true.
        // We just verify the flag exists, is a Bool, and is accessible.
        let flag: Bool = FeatureFlags.personalityEnabled
        XCTAssertTrue(flag is Bool, "personalityEnabled should be a Bool")
        // In test (DEBUG) environment, applyDevOverrides sets this to true
        // The important thing is the property exists and gates the feature
        XCTAssertNotNil(Optional(flag), "personalityEnabled should be accessible")
    }
}
