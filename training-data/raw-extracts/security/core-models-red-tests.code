    }

    func testIdentityTopicRawValues() {
        XCTAssertEqual(IdentityTopic.identity.rawValue, "identity")
        XCTAssertEqual(IdentityTopic.creator.rawValue, "creator")
        XCTAssertEqual(IdentityTopic.nameOrigin.rawValue, "name_origin")
        XCTAssertEqual(IdentityTopic.capabilities.rawValue, "capabilities")
        XCTAssertEqual(IdentityTopic.learning.rawValue, "learning")
