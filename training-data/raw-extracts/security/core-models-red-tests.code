/// Red tests for core model types.
///
/// Target files:
/// - Sources/SerenaCore/Models/Conversation.swift
/// - Sources/SerenaCore/Models/Message.swift
/// - Sources/SerenaCore/Models/FTAIDocument.swift
/// - Sources/SerenaCore/Models/SerenaError.swift
/// - Sources/SerenaCore/Models/PricingConfig.swift
/// - Sources/SerenaCore/Models/SerenaIdentity.swift
/// - Sources/SerenaCore/Models/SubscriptionStatus.swift
/// - Sources/SerenaCore/Models/SubscriptionTier.swift
/// - Sources/SerenaCore/Models/UserConfig.swift
/// - Sources/SerenaCore/Models/UserTier.swift

import XCTest
@testable import SerenaCore

@MainActor
final class CoreModelsRedTests: XCTestCase {

    // MARK: - Message & MessageRole

    func testMessageConvenienceInit() {
        let msg = Message(content: "hello", role: .user)
        XCTAssertEqual(msg.content, "hello")
        XCTAssertEqual(msg.role, .user)
        XCTAssertFalse(msg.id.uuidString.isEmpty)
    }

    func testMessageFullInit() {
        let id = UUID()
        let date = Date(timeIntervalSince1970: 1_000_000)
        let msg = Message(id: id, content: "hi", role: .assistant, timestamp: date)
        XCTAssertEqual(msg.id, id)
        XCTAssertEqual(msg.timestamp, date)
    }

    func testMessageCodableRoundtrip() throws {
        let original = Message(content: "roundtrip", role: .assistant)
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(Message.self, from: data)
        XCTAssertEqual(original, decoded)
    }

    func testMessageRoleDisplayNames() {
        XCTAssertEqual(MessageRole.user.displayName, "You")
        XCTAssertEqual(MessageRole.assistant.displayName, "SerenaNet")
    }

    func testMessageRoleCaseIterable() {
        XCTAssertEqual(MessageRole.allCases.count, 2)
    }

    func testMessageRoleRawValues() {
        XCTAssertEqual(MessageRole.user.rawValue, "user")
        XCTAssertEqual(MessageRole.assistant.rawValue, "assistant")
    }

    func testMessageEquality() {
        let id = UUID()
        let date = Date()
        let a = Message(id: id, content: "x", role: .user, timestamp: date)
        let b = Message(id: id, content: "x", role: .user, timestamp: date)
        XCTAssertEqual(a, b)
    }

    func testMessageInequality() {
        let a = Message(content: "a", role: .user)
        let b = Message(content: "b", role: .user)
        XCTAssertNotEqual(a, b)
    }

    // MARK: - Conversation

    func testConversationDefaultTitle() {
        let conv = Conversation()
        XCTAssertEqual(conv.title, "New Conversation")
        XCTAssertTrue(conv.isEmpty)
        XCTAssertNil(conv.lastMessage)
    }

    func testConversationCustomTitle() {
        let conv = Conversation(title: "My Chat")
        XCTAssertEqual(conv.title, "My Chat")
    }

    func testConversationFullInit() {
        let id = UUID()
        let now = Date()
        let msgs = [Message(content: "hi", role: .user)]
        let conv = Conversation(id: id, title: "T", messages: msgs, createdAt: now, updatedAt: now)
        XCTAssertEqual(conv.id, id)
        XCTAssertEqual(conv.messages.count, 1)
    }

    func testConversationAddMessageUpdatesTimestamp() {
        var conv = Conversation()
        let before = conv.updatedAt
        // Small delay to ensure timestamp differs
        let msg = Message(content: "test", role: .user)
        conv.addMessage(msg)
        XCTAssertGreaterThanOrEqual(conv.updatedAt, before)
        XCTAssertFalse(conv.isEmpty)
        let last = try! XCTUnwrap(conv.lastMessage)
        XCTAssertEqual(last.content, "test")
    }

    func testConversationAutoTitleFromFirstUserMessage() {
        var conv = Conversation()
        // Add assistant message first — should not trigger title change
        conv.addMessage(Message(content: "Hello!", role: .assistant))
        XCTAssertEqual(conv.title, "New Conversation")

        // Now add user message — should auto-title
        conv.addMessage(Message(content: "Short question", role: .user))
        XCTAssertEqual(conv.title, "Short question")
    }

    func testConversationAutoTitleTruncatesLongMessages() {
        var conv = Conversation()
        let longMsg = String(repeating: "a", count: 100)
        conv.addMessage(Message(content: longMsg, role: .user))
        XCTAssertTrue(conv.title.hasSuffix("..."))
        // 50 chars + "..."
        XCTAssertEqual(conv.title.count, 53)
    }

    func testConversationAutoTitleDoesNotOverwrite() {
        var conv = Conversation(title: "Custom Title")
        conv.addMessage(Message(content: "new msg", role: .user))
        // Custom title should remain
        XCTAssertEqual(conv.title, "Custom Title")
    }

    func testConversationGetContextMessagesDefault() {
        var conv = Conversation()
        for i in 0..<30 {
            conv.addMessage(Message(content: "msg \(i)", role: i % 2 == 0 ? .user : .assistant))
        }
        // Default limit=10 means 20 messages
        let context = conv.getContextMessages()
        XCTAssertEqual(context.count, 20)
        // Should be the last 20
        XCTAssertEqual(context.first?.content, "msg 10")
    }

    func testConversationGetContextMessagesCustomLimit() {
        var conv = Conversation()
        for i in 0..<10 {
            conv.addMessage(Message(content: "\(i)", role: .user))
        }
        let context = conv.getContextMessages(limit: 2)
        XCTAssertEqual(context.count, 4)
    }

    func testConversationGetContextMessagesFewerThanLimit() {
        var conv = Conversation()
        conv.addMessage(Message(content: "only", role: .user))
        let context = conv.getContextMessages()
        XCTAssertEqual(context.count, 1)
    }

    func testConversationCodableRoundtrip() throws {
        var conv = Conversation(title: "Test")
        conv.addMessage(Message(content: "hi", role: .user))
        let data = try JSONEncoder().encode(conv)
        let decoded = try JSONDecoder().decode(Conversation.self, from: data)
        XCTAssertEqual(conv, decoded)
    }

    // MARK: - FTAIDocument

    func testFTAIDocumentBasicInit() {
        let doc = FTAIDocument(version: "1.0", content: "hello")
        XCTAssertEqual(doc.version, "1.0")
        XCTAssertEqual(doc.content, "hello")
        XCTAssertTrue(doc.metadata.isEmpty)
        XCTAssertNil(doc.schema)
    }

    func testFTAIDocumentWithMetadataAndSchema() {
        let field = FTAIField(name: "title", type: .string, required: true, description: "doc title")
        let schema = FTAISchema(name: "TestSchema", version: "1.0", fields: [field], description: "A test schema")
        let doc = FTAIDocument(version: "2.0", metadata: ["author": "test"], content: "body", schema: schema)
        XCTAssertEqual(doc.metadata["author"], "test")
        let unwrappedSchema = try! XCTUnwrap(doc.schema)
        XCTAssertEqual(unwrappedSchema.name, "TestSchema")
        XCTAssertEqual(unwrappedSchema.fields.count, 1)
        XCTAssertEqual(unwrappedSchema.fields[0].type, .string)
        XCTAssertTrue(unwrappedSchema.fields[0].required)
    }

    func testFTAIDocumentCodableRoundtrip() throws {
        let field = FTAIField(name: "count", type: .integer)
        let schema = FTAISchema(name: "S", version: "1", fields: [field])
        let doc = FTAIDocument(version: "1.0", metadata: ["k": "v"], content: "c", schema: schema)
        let data = try JSONEncoder().encode(doc)
        let decoded = try JSONDecoder().decode(FTAIDocument.self, from: data)
        XCTAssertEqual(doc, decoded)
    }

    func testFTAIFieldTypeDisplayNames() {
        XCTAssertEqual(FTAIFieldType.string.displayName, "String")
        XCTAssertEqual(FTAIFieldType.integer.displayName, "Integer")
        XCTAssertEqual(FTAIFieldType.boolean.displayName, "Boolean")
        XCTAssertEqual(FTAIFieldType.array.displayName, "Array")
        XCTAssertEqual(FTAIFieldType.object.displayName, "Object")
        XCTAssertEqual(FTAIFieldType.date.displayName, "Date")
    }

    func testFTAIFieldTypeCaseIterable() {
        XCTAssertEqual(FTAIFieldType.allCases.count, 6)
    }

    func testFTAIFieldDefaultValues() {
        let field = FTAIField(name: "f", type: .boolean)
        XCTAssertFalse(field.required)
        XCTAssertNil(field.description)
    }

    func testFTAISchemaDefaultDescription() {
        let schema = FTAISchema(name: "S", version: "1", fields: [])
        XCTAssertNil(schema.description)
    }

    // MARK: - SerenaError

    func testSerenaErrorDescriptions() {
        // Verify every case produces a non-nil errorDescription
        let errors: [SerenaError] = [
            .aiModelNotLoaded,
            .aiModelNotFound("missing"),
            .aiModelInitializationFailed("fail"),
            .aiResponseGenerationFailed("gen"),
            .aiProcessingError("proc"),
            .voicePermissionDenied,
            .voiceRecognitionFailed("vr"),
            .voiceRecognitionUnavailable,
            .voiceRecognitionSetupFailed,
            .databaseError("db"),
            .networkUnavailable,
            .invalidFTAIFormat("fmt"),
            .configurationError("cfg"),
            .conversationNotFound,
            .emptyMessage,
            .unknownError("unk"),
        ]
        for error in errors {
            XCTAssertNotNil(error.errorDescription, "Missing errorDescription for \(error)")
            XCTAssertNotNil(error.recoverySuggestion, "Missing recoverySuggestion for \(error)")
        }
    }

    func testSerenaErrorDescriptionContainsMessage() {
        let err = SerenaError.databaseError("corruption")
        let desc = try! XCTUnwrap(err.errorDescription)
        XCTAssertTrue(desc.contains("corruption"))
    }

    func testSerenaErrorRecoverableClassification() {
        // Recoverable
        XCTAssertTrue(SerenaError.aiModelNotLoaded.isRecoverable)
        XCTAssertTrue(SerenaError.networkUnavailable.isRecoverable)
        XCTAssertTrue(SerenaError.emptyMessage.isRecoverable)
        XCTAssertTrue(SerenaError.conversationNotFound.isRecoverable)
        XCTAssertTrue(SerenaError.aiResponseGenerationFailed("x").isRecoverable)
        XCTAssertTrue(SerenaError.voiceRecognitionFailed("x").isRecoverable)
        XCTAssertTrue(SerenaError.invalidFTAIFormat("x").isRecoverable)
        XCTAssertTrue(SerenaError.unknownError("x").isRecoverable)

        // Not recoverable
        XCTAssertFalse(SerenaError.aiModelNotFound("x").isRecoverable)
        XCTAssertFalse(SerenaError.aiModelInitializationFailed("x").isRecoverable)
        XCTAssertFalse(SerenaError.databaseError("x").isRecoverable)
        XCTAssertFalse(SerenaError.configurationError("x").isRecoverable)
    }

    func testSerenaErrorSeverityClassification() {
        XCTAssertEqual(SerenaError.networkUnavailable.severity, .info)
        XCTAssertEqual(SerenaError.emptyMessage.severity, .info)
        XCTAssertEqual(SerenaError.voicePermissionDenied.severity, .warning)
        XCTAssertEqual(SerenaError.conversationNotFound.severity, .warning)
        XCTAssertEqual(SerenaError.aiModelNotLoaded.severity, .error)
        XCTAssertEqual(SerenaError.aiResponseGenerationFailed("x").severity, .error)
        XCTAssertEqual(SerenaError.databaseError("x").severity, .critical)
        XCTAssertEqual(SerenaError.unknownError("x").severity, .critical)
    }

    func testSerenaErrorEquatable() {
        XCTAssertEqual(SerenaError.aiModelNotLoaded, SerenaError.aiModelNotLoaded)
        XCTAssertEqual(SerenaError.databaseError("a"), SerenaError.databaseError("a"))
        XCTAssertNotEqual(SerenaError.databaseError("a"), SerenaError.databaseError("b"))
        XCTAssertNotEqual(SerenaError.emptyMessage, SerenaError.networkUnavailable)
    }

    func testErrorSeveritySystemImageNames() {
        XCTAssertEqual(ErrorSeverity.info.systemImageName, "info.circle")
        XCTAssertEqual(ErrorSeverity.warning.systemImageName, "exclamationmark.triangle")
        XCTAssertEqual(ErrorSeverity.error.systemImageName, "xmark.circle")
        XCTAssertEqual(ErrorSeverity.critical.systemImageName, "exclamationmark.octagon")
    }

    func testErrorSeverityColors() {
        XCTAssertEqual(ErrorSeverity.info.color, "blue")
        XCTAssertEqual(ErrorSeverity.warning.color, "orange")
        XCTAssertEqual(ErrorSeverity.error.color, "red")
        XCTAssertEqual(ErrorSeverity.critical.color, "red")
    }

    // MARK: - PricingConfig

    func testPricingConfigDefaults() {
        let config = PricingConfig.default
        XCTAssertEqual(config.corePrice, 0)
        XCTAssertEqual(config.plusPrice, 20.00)
        XCTAssertEqual(config.businessPrice, 99.99)
        XCTAssertEqual(config.additionalSeatPrice, 15)
        XCTAssertEqual(config.currency, "USD")
    }

    func testPricingConfigCustomInit() {
        let config = PricingConfig(corePrice: 5, plusPrice: 25, businessPrice: 120, additionalSeatPrice: 20, currency: "EUR")
        XCTAssertEqual(config.corePrice, 5)
        XCTAssertEqual(config.currency, "EUR")
        XCTAssertEqual(config.additionalSeatPrice, 20)
    }

    func testPricingConfigCodableRoundtrip() throws {
        let original = PricingConfig(corePrice: 0, plusPrice: 10, businessPrice: 50)
        let encoder = JSONEncoder()
        let data = try encoder.encode(original)
        let decoded = try JSONDecoder().decode(PricingConfig.self, from: data)
        XCTAssertEqual(decoded.corePrice, original.corePrice)
        XCTAssertEqual(decoded.plusPrice, original.plusPrice)
        XCTAssertEqual(decoded.businessPrice, original.businessPrice)
    }

    func testJakeBundlePricingDefaults() {
        let jake = PricingConfig.JakeBundlePricing.default
        XCTAssertEqual(jake.jakePersonalBundle, 189)
        XCTAssertEqual(jake.jakeBusinessBundle, 999)
        XCTAssertEqual(jake.jakePersonalHardware, 4000)
        XCTAssertEqual(jake.jakeBusinessHardware, 8000)
    }

    func testPricingConfigJakeBundlingProperty() {
        let config = PricingConfig.default
        let bundling = config.jakeBundling
        XCTAssertEqual(bundling.jakePersonalBundle, 189)
    }

    // MARK: - SerenaIdentity

    func testSerenaIdentityConstants() {
        XCTAssertEqual(SerenaIdentity.name, "Serena")
        XCTAssertEqual(SerenaIdentity.creator, "FolkTech AI")
        XCTAssertEqual(SerenaIdentity.founderName, "Mike Folk")
        XCTAssertFalse(SerenaIdentity.founderBackground.isEmpty)
    }

    func testSerenaIdentityCapabilities() {
        XCTAssertFalse(SerenaIdentity.capabilities.isEmpty)
        XCTAssertTrue(SerenaIdentity.capabilities.count >= 4)
    }

    func testSerenaIdentityLearningSystems() {
        XCTAssertEqual(SerenaIdentity.learningSystems.count, 3)
        XCTAssertNotNil(SerenaIdentity.learningSystems["Personal Learning"])
        XCTAssertNotNil(SerenaIdentity.learningSystems["Domain Expansion"])
        XCTAssertNotNil(SerenaIdentity.learningSystems["Style Adaptation"])
