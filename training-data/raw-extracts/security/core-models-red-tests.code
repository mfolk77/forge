    // MARK: - Identity Query Detection

    func testDetectIdentityQueryWhoAreYou() {
        let result = SerenaIdentity.detectIdentityQuery("Who are you?")
        XCTAssertTrue(result.isIdentityQuery)
        XCTAssertEqual(result.topic, .identity)
    }

    func testDetectIdentityQueryCreator() {
        let result = SerenaIdentity.detectIdentityQuery("Who created you?")
        XCTAssertTrue(result.isIdentityQuery)
        XCTAssertEqual(result.topic, .creator)
    }

    func testDetectIdentityQueryCapabilities() {
        let result = SerenaIdentity.detectIdentityQuery("What can you do?")
        XCTAssertTrue(result.isIdentityQuery)
        XCTAssertEqual(result.topic, .capabilities)
    }

    func testDetectIdentityQueryLearning() {
        let result = SerenaIdentity.detectIdentityQuery("How do you learn?")
        XCTAssertTrue(result.isIdentityQuery)
        XCTAssertEqual(result.topic, .learning)
    }

    func testDetectIdentityQueryPrivacy() {
        let result = SerenaIdentity.detectIdentityQuery("Is my data safe?")
