    // MARK: - SubscriptionTier

    func testSubscriptionTierDisplayNames() {
        XCTAssertEqual(SubscriptionTier.core.displayName, "Serena Core")
        XCTAssertEqual(SubscriptionTier.plus.displayName, "Serena Plus")
        XCTAssertEqual(SubscriptionTier.business.displayName, "Serena Business")
        XCTAssertEqual(SubscriptionTier.expired.displayName, "Expired")
    }

    func testSubscriptionTierMonthlyPriceDefaults() {
        XCTAssertEqual(SubscriptionTier.core.monthlyPrice(), 0)
        XCTAssertEqual(SubscriptionTier.plus.monthlyPrice(), 20.00)
        XCTAssertEqual(SubscriptionTier.business.monthlyPrice(), 99.99)
        XCTAssertEqual(SubscriptionTier.expired.monthlyPrice(), 0)
    }

    func testSubscriptionTierMonthlyPriceCustomConfig() {
        let config = PricingConfig(corePrice: 5, plusPrice: 30, businessPrice: 150)
        XCTAssertEqual(SubscriptionTier.core.monthlyPrice(from: config), 5)
        XCTAssertEqual(SubscriptionTier.plus.monthlyPrice(from: config), 30)
        XCTAssertEqual(SubscriptionTier.business.monthlyPrice(from: config), 150)
    }

    func testSubscriptionTierFeatureGates() {
        // Knowledge expansion
        XCTAssertFalse(SubscriptionTier.core.allowsKnowledgeExpansion)
        XCTAssertTrue(SubscriptionTier.plus.allowsKnowledgeExpansion)
        XCTAssertTrue(SubscriptionTier.business.allowsKnowledgeExpansion)
        XCTAssertFalse(SubscriptionTier.expired.allowsKnowledgeExpansion)

        // Advanced models
        XCTAssertFalse(SubscriptionTier.core.allowsAdvancedModels)
        XCTAssertTrue(SubscriptionTier.plus.allowsAdvancedModels)
        XCTAssertTrue(SubscriptionTier.business.allowsAdvancedModels)

        // Thinking models — business only
        XCTAssertFalse(SubscriptionTier.core.allowsThinkingModels)
        XCTAssertFalse(SubscriptionTier.plus.allowsThinkingModels)
        XCTAssertTrue(SubscriptionTier.business.allowsThinkingModels)

        // Proactive AI
        XCTAssertFalse(SubscriptionTier.core.allowsProactiveAI)
        XCTAssertTrue(SubscriptionTier.plus.allowsProactiveAI)
        XCTAssertTrue(SubscriptionTier.business.allowsProactiveAI)
    }

    func testSubscriptionTierVerificationIntervals() {
        XCTAssertEqual(SubscriptionTier.core.verificationInterval, 30 * 24 * 60 * 60)
        XCTAssertEqual(SubscriptionTier.plus.verificationInterval, 7 * 24 * 60 * 60)
        XCTAssertEqual(SubscriptionTier.business.verificationInterval, 24 * 60 * 60)
        XCTAssertEqual(SubscriptionTier.expired.verificationInterval, 24 * 60 * 60)
    }

    func testSubscriptionTierGracePeriodDays() {
        XCTAssertEqual(SubscriptionTier.core.gracePeriodDays, 7)
        XCTAssertEqual(SubscriptionTier.plus.gracePeriodDays, 3)
        XCTAssertEqual(SubscriptionTier.business.gracePeriodDays, 1)
        XCTAssertEqual(SubscriptionTier.expired.gracePeriodDays, 0)
    }

    func testSubscriptionTierMaxDevices() {
        XCTAssertEqual(SubscriptionTier.core.maxDevices, 2)
        XCTAssertEqual(SubscriptionTier.plus.maxDevices, 3)
        XCTAssertEqual(SubscriptionTier.business.maxDevices, 5)
        XCTAssertEqual(SubscriptionTier.expired.maxDevices, 1)
    }

    func testSubscriptionTierKnowledgeExpansionLimits() {
        XCTAssertEqual(SubscriptionTier.core.knowledgeExpansionDailyLimit, 0)
        XCTAssertEqual(SubscriptionTier.plus.knowledgeExpansionDailyLimit, 50)
        XCTAssertNil(SubscriptionTier.business.knowledgeExpansionDailyLimit)
        XCTAssertEqual(SubscriptionTier.expired.knowledgeExpansionDailyLimit, 0)
    }

    func testSubscriptionTierBenefits() {
        XCTAssertFalse(SubscriptionTier.core.benefits.isEmpty)
        XCTAssertFalse(SubscriptionTier.plus.benefits.isEmpty)
        XCTAssertFalse(SubscriptionTier.business.benefits.isEmpty)
        XCTAssertTrue(SubscriptionTier.expired.benefits.isEmpty)
        // Plus should have more benefits than core
        XCTAssertGreaterThan(SubscriptionTier.plus.benefits.count, SubscriptionTier.core.benefits.count)
    }

    func testSubscriptionTierUpgradeURLs() {
        XCTAssertTrue(SubscriptionTier.core.upgradeURL.absoluteString.contains("core"))
        XCTAssertTrue(SubscriptionTier.plus.upgradeURL.absoluteString.contains("plus"))
        XCTAssertTrue(SubscriptionTier.business.upgradeURL.absoluteString.contains("business"))
        XCTAssertTrue(SubscriptionTier.expired.upgradeURL.absoluteString.contains("renew"))
    }

    func testSubscriptionTierCodableRoundtrip() throws {
        for tier in SubscriptionTier.allCases {
            let data = try JSONEncoder().encode(tier)
            let decoded = try JSONDecoder().decode(SubscriptionTier.self, from: data)
            XCTAssertEqual(tier, decoded)
        }
    }

    // MARK: - SubscriptionStatus

    func testSubscriptionStatusExpiredFactory() {
        let status = SubscriptionStatus.expired(deviceId: "dev1")
        XCTAssertEqual(status.tier, .expired)
        XCTAssertEqual(status.deviceId, "dev1")
        XCTAssertFalse(status.isActive)
        XCTAssertTrue(status.isExpired)
        XCTAssertNil(status.gracePeriodEndsAt)
        XCTAssertFalse(status.isInGracePeriod)
    }

    func testSubscriptionStatusTrialFactory() {
        let status = SubscriptionStatus.trial(deviceId: "dev2")
        XCTAssertEqual(status.tier, .plus)
        XCTAssertEqual(status.deviceId, "dev2")
        XCTAssertTrue(status.isActive)
        XCTAssertFalse(status.isExpired)
        // Should expire in ~7 days
        XCTAssertGreaterThanOrEqual(status.daysUntilExpiration, 6)
        XCTAssertLessThanOrEqual(status.daysUntilExpiration, 7)
    }

    func testSubscriptionStatusActiveWithFutureExpiry() {
        let futureDate = Calendar.current.date(byAdding: .day, value: 30, to: Date())!
        let status = SubscriptionStatus(
            tier: .plus,
            expiresAt: futureDate,
            lastVerified: Date(),
            gracePeriodEndsAt: nil,
            isInGracePeriod: false,
            deviceId: "dev"
        )
        XCTAssertTrue(status.isActive)
        XCTAssertFalse(status.isExpired)
        let days = status.daysUntilExpiration
        XCTAssertGreaterThanOrEqual(days, 29)
        XCTAssertLessThanOrEqual(days, 30)
    }

    func testSubscriptionStatusExpiredWithPastExpiry() {
        let pastDate = Calendar.current.date(byAdding: .day, value: -5, to: Date())!
        let status = SubscriptionStatus(
            tier: .plus,
            expiresAt: pastDate,
            lastVerified: Date(),
            gracePeriodEndsAt: nil,
            isInGracePeriod: false,
            deviceId: "dev"
        )
        XCTAssertFalse(status.isActive)
        XCTAssertTrue(status.isExpired)
        XCTAssertEqual(status.daysUntilExpiration, 0)
    }

    func testSubscriptionStatusGracePeriodActive() {
        let pastExpiry = Calendar.current.date(byAdding: .day, value: -1, to: Date())!
        let futureGrace = Calendar.current.date(byAdding: .day, value: 2, to: Date())!
        let status = SubscriptionStatus(
            tier: .plus,
            expiresAt: pastExpiry,
            lastVerified: Date(),
            gracePeriodEndsAt: futureGrace,
            isInGracePeriod: true,
            deviceId: "dev"
        )
        XCTAssertTrue(status.isActive)
        let graceRemaining = try! XCTUnwrap(status.daysRemainingInGracePeriod)
        XCTAssertGreaterThanOrEqual(graceRemaining, 1)
    }

    func testSubscriptionStatusGracePeriodExpired() {
        let pastExpiry = Calendar.current.date(byAdding: .day, value: -10, to: Date())!
        let pastGrace = Calendar.current.date(byAdding: .day, value: -3, to: Date())!
        let status = SubscriptionStatus(
            tier: .plus,
            expiresAt: pastExpiry,
            lastVerified: Date(),
            gracePeriodEndsAt: pastGrace,
            isInGracePeriod: true,
            deviceId: "dev"
        )
        XCTAssertFalse(status.isActive)
        XCTAssertTrue(status.isExpired)
        XCTAssertEqual(status.daysRemainingInGracePeriod, 0)
    }

    func testSubscriptionStatusMessageActive() {
        let futureDate = Calendar.current.date(byAdding: .day, value: 30, to: Date())!
        let status = SubscriptionStatus(
            tier: .plus, expiresAt: futureDate, lastVerified: Date(),
            gracePeriodEndsAt: nil, isInGracePeriod: false, deviceId: "dev"
        )
        XCTAssertEqual(status.statusMessage, "Active")
    }

    func testSubscriptionStatusMessageExpiresSoon() {
        let soonDate = Calendar.current.date(byAdding: .day, value: 3, to: Date())!
        let status = SubscriptionStatus(
            tier: .plus, expiresAt: soonDate, lastVerified: Date(),
            gracePeriodEndsAt: nil, isInGracePeriod: false, deviceId: "dev"
        )
        XCTAssertTrue(status.statusMessage.contains("Expires in"))
    }

    func testSubscriptionStatusMessageExpired() {
        let status = SubscriptionStatus.expired(deviceId: "dev")
        XCTAssertEqual(status.statusMessage, "Subscription expired")
    }

    func testSubscriptionStatusMessageGracePeriod() {
        let pastExpiry = Calendar.current.date(byAdding: .day, value: -1, to: Date())!
        let futureGrace = Calendar.current.date(byAdding: .day, value: 5, to: Date())!
        let status = SubscriptionStatus(
            tier: .plus, expiresAt: pastExpiry, lastVerified: Date(),
            gracePeriodEndsAt: futureGrace, isInGracePeriod: true, deviceId: "dev"
        )
        XCTAssertTrue(status.statusMessage.contains("Grace period"))
    }

    func testSubscriptionStatusDaysRemainingNilWhenNoGracePeriod() {
        let status = SubscriptionStatus(
            tier: .core, expiresAt: Date(), lastVerified: Date(),
            gracePeriodEndsAt: nil, isInGracePeriod: false, deviceId: "dev"
        )
        XCTAssertNil(status.daysRemainingInGracePeriod)
    }

    func testSubscriptionStatusCodableRoundtrip() throws {
        let original = SubscriptionStatus.trial(deviceId: "roundtrip-dev")
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(SubscriptionStatus.self, from: data)
        XCTAssertEqual(decoded.tier, original.tier)
        XCTAssertEqual(decoded.deviceId, original.deviceId)
    }

    func testSubscriptionStatusLicenseKey() {
        var status = SubscriptionStatus.trial(deviceId: "dev")
        XCTAssertNil(status.licenseKey)
        status.licenseKey = "ABC-123"
        XCTAssertEqual(status.licenseKey, "ABC-123")
    }

    // MARK: - SubscriptionError

    func testSubscriptionErrorDescriptions() {
        let errors: [SubscriptionError] = [
            .noLicenseKey,
            .invalidLicenseKey,
            .licenseExpired,
            .deviceLimitExceeded,
            .verificationFailed(NSError(domain: "test", code: 1)),
            .networkUnavailable,
            .serverError(500),
        ]
        for error in errors {
            XCTAssertNotNil(error.errorDescription, "Missing errorDescription for \(error)")
        }
    }

    func testSubscriptionErrorServerErrorContainsCode() {
        let err = SubscriptionError.serverError(403)
        let desc = try! XCTUnwrap(err.errorDescription)
        XCTAssertTrue(desc.contains("403"))
    }

    // MARK: - UserConfig

    func testUserConfigDefaults() {
        let config = UserConfig.default
        XCTAssertEqual(config.nickname, "User")
        XCTAssertEqual(config.theme, .system)
        XCTAssertTrue(config.voiceInputEnabled)
        XCTAssertFalse(config.passcodeEnabled)
        XCTAssertTrue(config.rtaiEnabled)
        XCTAssertEqual(config.responseStyle, .balanced)
        XCTAssertEqual(config.occupation, "")
        XCTAssertEqual(config.aboutYou, "")
        XCTAssertEqual(config.customInstructions, "")
        XCTAssertEqual(config.weatherLocation, "")
    }

    func testUserConfigCustomInit() {
        let config = UserConfig(
            nickname: "Mike",
            theme: .dark,
            voiceInputEnabled: false,
            passcodeEnabled: true,
            rtaiEnabled: false,
            occupation: "Developer",
            aboutYou: "I like Swift",
            customInstructions: "Be brief",
            responseStyle: .technical,
            weatherLocation: "Las Vegas"
        )
        XCTAssertEqual(config.nickname, "Mike")
        XCTAssertEqual(config.theme, .dark)
        XCTAssertFalse(config.voiceInputEnabled)
        XCTAssertTrue(config.passcodeEnabled)
        XCTAssertEqual(config.occupation, "Developer")
        XCTAssertEqual(config.responseStyle, .technical)
        XCTAssertEqual(config.weatherLocation, "Las Vegas")
    }

    func testUserConfigCodableRoundtrip() throws {
        let original = UserConfig(nickname: "Test", theme: .light, responseStyle: .casual, weatherLocation: "NYC")
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(UserConfig.self, from: data)
        XCTAssertEqual(original, decoded)
    }

    func testUserConfigBackwardsCompatibleDecoding() throws {
        // Simulate an older config without new fields
        let json = """
        {
            "nickname": "OldUser",
            "theme": "dark",
            "voiceInputEnabled": true,
            "passcodeEnabled": false,
            "rtaiEnabled": true
        }
        """
        let data = Data(json.utf8)
        let config = try JSONDecoder().decode(UserConfig.self, from: data)
        XCTAssertEqual(config.nickname, "OldUser")
        XCTAssertEqual(config.theme, .dark)
        // New fields should default
        XCTAssertEqual(config.occupation, "")
        XCTAssertEqual(config.responseStyle, .balanced)
        XCTAssertEqual(config.weatherLocation, "")
    }

    func testUserConfigDecodesEmptyJSON() throws {
        let data = Data("{}".utf8)
        let config = try JSONDecoder().decode(UserConfig.self, from: data)
        XCTAssertEqual(config.nickname, "User")
        XCTAssertEqual(config.theme, .system)
    }

    // MARK: - ResponseStyle

    func testResponseStyleAllCases() {
        XCTAssertEqual(ResponseStyle.allCases.count, 4)
    }

    func testResponseStyleDisplayNames() {
        XCTAssertEqual(ResponseStyle.casual.displayName, "Casual & Friendly")
        XCTAssertEqual(ResponseStyle.balanced.displayName, "Balanced")
        XCTAssertEqual(ResponseStyle.professional.displayName, "Professional")
        XCTAssertEqual(ResponseStyle.technical.displayName, "Technical & Detailed")
    }

    func testResponseStyleDescriptions() {
        for style in ResponseStyle.allCases {
            XCTAssertFalse(style.description.isEmpty)
        }
    }

    func testResponseStyleDirectives() {
        // Balanced has empty directive
        XCTAssertEqual(ResponseStyle.balanced.directive, "")
        // Others have non-empty directives
        XCTAssertFalse(ResponseStyle.casual.directive.isEmpty)
        XCTAssertFalse(ResponseStyle.professional.directive.isEmpty)
        XCTAssertFalse(ResponseStyle.technical.directive.isEmpty)
    }

    func testResponseStyleCodableRoundtrip() throws {
        for style in ResponseStyle.allCases {
            let data = try JSONEncoder().encode(style)
            let decoded = try JSONDecoder().decode(ResponseStyle.self, from: data)
            XCTAssertEqual(style, decoded)
        }
    }

    // MARK: - AppTheme

    func testAppThemeDisplayNames() {
        XCTAssertEqual(AppTheme.light.displayName, "Light")
        XCTAssertEqual(AppTheme.dark.displayName, "Dark")
        XCTAssertEqual(AppTheme.system.displayName, "System")
    }

    func testAppThemeColorScheme() {
        XCTAssertEqual(AppTheme.light.colorScheme, .light)
        XCTAssertEqual(AppTheme.dark.colorScheme, .dark)
        XCTAssertNil(AppTheme.system.colorScheme)
    }

    func testAppThemeCaseIterable() {
        XCTAssertEqual(AppTheme.allCases.count, 3)
    }

    // MARK: - AIParameters

    func testAIParametersDefaults() {
        let params = AIParameters()
        XCTAssertEqual(params.temperature, 0.7)
        XCTAssertEqual(params.maxTokens, 1000)
        XCTAssertEqual(params.contextWindow, 10)
    }

    func testAIParametersClamping() {
        let params = AIParameters(temperature: 5.0, maxTokens: 99999, contextWindow: 100)
        XCTAssertEqual(params.temperature, 2.0)
        XCTAssertEqual(params.maxTokens, 4000)
        XCTAssertEqual(params.contextWindow, 20)

        let paramsLow = AIParameters(temperature: -1.0, maxTokens: 1, contextWindow: 0)
        XCTAssertEqual(paramsLow.temperature, 0.0)
        XCTAssertEqual(paramsLow.maxTokens, 100)
        XCTAssertEqual(paramsLow.contextWindow, 1)
    }

    func testAIParametersCodableRoundtrip() throws {
        let original = AIParameters(temperature: 1.2, maxTokens: 2000, contextWindow: 5)
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(AIParameters.self, from: data)
        XCTAssertEqual(original, decoded)
    }

    // MARK: - VoiceSettings

    func testVoiceSettingsDefaults() {
        let settings = VoiceSettings()
        XCTAssertTrue(settings.noiseReductionEnabled)
        XCTAssertTrue(settings.voiceCommandsEnabled)
        XCTAssertFalse(settings.autoSendEnabled)
        XCTAssertEqual(settings.microphoneSensitivity, 0.5)
        XCTAssertEqual(settings.speechTimeout, 3.0)
        XCTAssertEqual(settings.language, "en-US")
    }

    func testVoiceSettingsClamping() {
        let settings = VoiceSettings(microphoneSensitivity: 2.0, speechTimeout: 100.0)
        XCTAssertEqual(settings.microphoneSensitivity, 1.0)
        XCTAssertEqual(settings.speechTimeout, 10.0)

        let settingsLow = VoiceSettings(microphoneSensitivity: -1.0, speechTimeout: 0.1)
        XCTAssertEqual(settingsLow.microphoneSensitivity, 0.0)
        XCTAssertEqual(settingsLow.speechTimeout, 1.0)
    }

    func testVoiceSettingsCodableRoundtrip() throws {
        let original = VoiceSettings(language: "fr-FR")
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(VoiceSettings.self, from: data)
        XCTAssertEqual(original, decoded)
    }

    // MARK: - UserTier

    func testUserTierRawValues() {
        XCTAssertEqual(UserTier.free.rawValue, "free")
        XCTAssertEqual(UserTier.paid.rawValue, "paid")
    }

    func testUserTierMemoryRetention() {
        XCTAssertEqual(UserTier.free.memoryRetentionDays, 30)
        XCTAssertEqual(UserTier.paid.memoryRetentionDays, 3650)
    }

    func testUserTierMaxHistoryMessages() {
        XCTAssertEqual(UserTier.free.maxHistoryMessages, 1000)
        XCTAssertEqual(UserTier.paid.maxHistoryMessages, 10000)
    }

    func testUserTierDisplayNames() {
        XCTAssertEqual(UserTier.free.displayName, "Free")
        XCTAssertEqual(UserTier.paid.displayName, "Paid")
    }

    func testUserTierFeatures() {
        XCTAssertFalse(UserTier.free.features.isEmpty)
        XCTAssertFalse(UserTier.paid.features.isEmpty)
        XCTAssertGreaterThan(UserTier.paid.features.count, UserTier.free.features.count)
    }

    func testUserTierCodableRoundtrip() throws {
        for tier in [UserTier.free, UserTier.paid] {
            let data = try JSONEncoder().encode(tier)
            let decoded = try JSONDecoder().decode(UserTier.self, from: data)
            XCTAssertEqual(tier, decoded)
        }
    }

    // MARK: - UserTierConfig

    func testUserTierConfigDefaults() {
        let config = UserTierConfig()
        XCTAssertEqual(config.currentTier, .free)
        XCTAssertNil(config.lastCleanupDate)
    }

    func testUserTierConfigPaidInit() {
        let config = UserTierConfig(tier: .paid)
        XCTAssertEqual(config.currentTier, .paid)
    }

    func testUserTierConfigIsWithinRetentionRecent() {
        let config = UserTierConfig(tier: .free)
        let recentDate = Calendar.current.date(byAdding: .day, value: -10, to: Date())!
        XCTAssertTrue(config.isWithinRetention(recentDate))
    }

    func testUserTierConfigIsWithinRetentionOld() {
        let config = UserTierConfig(tier: .free)
        let oldDate = Calendar.current.date(byAdding: .day, value: -60, to: Date())!
        XCTAssertFalse(config.isWithinRetention(oldDate))
    }

    func testUserTierConfigPaidRetainsFarBack() {
        let config = UserTierConfig(tier: .paid)
        let farBack = Calendar.current.date(byAdding: .year, value: -5, to: Date())!
        XCTAssertTrue(config.isWithinRetention(farBack))
    }

    func testUserTierConfigShouldRunCleanupNoLastCleanup() {
        let config = UserTierConfig()
        XCTAssertTrue(config.shouldRunCleanup())
    }

    func testUserTierConfigShouldRunCleanupRecentCleanup() {
        var config = UserTierConfig()
        config.lastCleanupDate = Date()
        XCTAssertFalse(config.shouldRunCleanup())
    }

    func testUserTierConfigShouldRunCleanupOldCleanup() {
        var config = UserTierConfig()
        config.lastCleanupDate = Calendar.current.date(byAdding: .day, value: -2, to: Date())
        XCTAssertTrue(config.shouldRunCleanup())
    }

    func testUserTierConfigCodableRoundtrip() throws {
        var original = UserTierConfig(tier: .paid)
        original.lastCleanupDate = Date()
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(UserTierConfig.self, from: data)
        XCTAssertEqual(decoded.currentTier, original.currentTier)
    }
}
