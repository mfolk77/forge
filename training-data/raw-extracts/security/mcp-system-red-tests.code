    // MARK: - MCPTypes: MCPClientCapabilities

    func test_mcpClientCapabilities_default() {
        let caps = MCPClientCapabilities.default
        XCTAssertNil(caps.roots)
        XCTAssertNil(caps.sampling)
        XCTAssertNil(caps.experimental)
    }

    func test_mcpClientCapabilities_withRoots() {
        let caps = MCPClientCapabilities(
            roots: MCPClientCapabilities.RootsCapability(listChanged: true)
        )
        XCTAssertNotNil(caps.roots)
        XCTAssertEqual(caps.roots?.listChanged, true)
        XCTAssertNil(caps.sampling)
    }

    func test_mcpClientCapabilities_codableRoundtrip() throws {
        let caps = MCPClientCapabilities(
            roots: MCPClientCapabilities.RootsCapability(listChanged: false),
            sampling: MCPClientCapabilities.SamplingCapability()
        )
        let data = try JSONEncoder().encode(caps)
        let decoded = try JSONDecoder().decode(MCPClientCapabilities.self, from: data)
        XCTAssertEqual(decoded.roots?.listChanged, false)
        XCTAssertNotNil(decoded.sampling)
    }

