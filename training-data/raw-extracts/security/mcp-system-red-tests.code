        XCTAssertEqual(params.protocolVersion, "2025-01-01")
    }

    // MARK: - MCPTypes: MCPServerCapabilities edge cases

    func test_mcpServerCapabilities_allNil() throws {
        let json = """
        {}
        """.data(using: .utf8)!
        let caps = try JSONDecoder().decode(MCPServerCapabilities.self, from: json)
        let supportsTools = caps.supportsTools
        let supportsResources = caps.supportsResources
        let supportsPrompts = caps.supportsPrompts
        XCTAssertFalse(supportsTools)
        XCTAssertFalse(supportsResources)
        XCTAssertFalse(supportsPrompts)
    }

    func test_mcpServerCapabilities_withLogging() throws {
        let json = """
        {"logging": {}}
        """.data(using: .utf8)!
        let caps = try JSONDecoder().decode(MCPServerCapabilities.self, from: json)
        XCTAssertNotNil(caps.logging)
    }

    func test_mcpServerCapabilities_withExperimental() throws {
        let json = """
        {"experimental": {"feature_x": true}}
        """.data(using: .utf8)!
        let caps = try JSONDecoder().decode(MCPServerCapabilities.self, from: json)
        XCTAssertNotNil(caps.experimental)
        XCTAssertEqual(caps.experimental?["feature_x"]?.boolValue, true)
    }

    // MARK: - MCPTypes: MCPToolListResult with cursor

    func test_mcpToolListResult_withCursor() throws {
        let json = """
        {
            "tools": [{"name": "t1", "inputSchema": {"type": "object"}}],
            "nextCursor": "page2"
        }
        """.data(using: .utf8)!
        let result = try JSONDecoder().decode(MCPToolListResult.self, from: json)
        XCTAssertEqual(result.tools.count, 1)
        XCTAssertEqual(result.nextCursor, "page2")
    }

    // MARK: - MCPTransport: MCPError descriptions contain context

    func test_mcpError_serverNotFoundContainsPath() {
        let error = MCPError.serverNotFound("/usr/local/bin/mcp-server")
        let desc = error.errorDescription!
        XCTAssertTrue(desc.contains("/usr/local/bin/mcp-server"))
    }

    func test_mcpError_transportErrorContainsMessage() {
        let error = MCPError.transportError("pipe broken")
        let desc = error.errorDescription!
        XCTAssertTrue(desc.contains("pipe broken"))
    }

    func test_mcpError_unknownToolContainsName() {
        let error = MCPError.unknownTool("fancy_tool")
        let desc = error.errorDescription!
        XCTAssertTrue(desc.contains("fancy_tool"))
    }

    func test_mcpError_capabilityNotSupportedContainsCapability() {
        let error = MCPError.capabilityNotSupported("resources")
        let desc = error.errorDescription!
        XCTAssertTrue(desc.contains("resources"))
    }

    func test_mcpError_processSpawnFailedContainsReason() {
        let error = MCPError.processSpawnFailed("not found on PATH")
        let desc = error.errorDescription!
        XCTAssertTrue(desc.contains("not found on PATH"))
    }

    func test_mcpError_jsonErrorContainsUnderlying() {
        let underlying = NSError(domain: "json", code: 0, userInfo: [NSLocalizedDescriptionKey: "bad json"])
        let error = MCPError.jsonError(underlying)
        let desc = error.errorDescription!
        XCTAssertTrue(desc.contains("bad json"))
    }

    // MARK: - MCPTransport: MCPTransportConfig

    func test_mcpTransportConfig_zeroTimeout() {
        let config = MCPTransportConfig(requestTimeout: 0)
        XCTAssertEqual(config.requestTimeout, 0)
    }

    func test_mcpTransportConfig_noReconnect() {
        let config = MCPTransportConfig(autoReconnect: false, maxReconnectAttempts: 0)
        XCTAssertFalse(config.autoReconnect)
        XCTAssertEqual(config.maxReconnectAttempts, 0)
    }

    // MARK: - MCPTransport: MCPTransportState

    func test_mcpTransportState_errorCase() {
        let state = MCPTransportState.error(.timeout)
        if case .error(let err) = state {
            let desc = err.errorDescription
            XCTAssertNotNil(desc)
        } else {
            XCTFail("Expected error state")
        }
    }

    func test_mcpTransportState_allCases() {
        // Verify all cases can be constructed without crash
        let states: [MCPTransportState] = [
            .disconnected,
            .connecting,
            .connected,
            .disconnecting,
            .error(.cancelled)
        ]
        XCTAssertEqual(states.count, 5)
    }

    // MARK: - MCPServerConfig

    func test_mcpServerConfig_init() {
        let config = MCPServerConfig(
            name: "test-server",
            command: "/usr/local/bin/npx",
            args: ["-y", "@mcp/server-test"],
            env: ["API_KEY": "secret123"]
        )
        XCTAssertEqual(config.name, "test-server")
        XCTAssertEqual(config.command, "/usr/local/bin/npx")
        XCTAssertEqual(config.args, ["-y", "@mcp/server-test"])
        XCTAssertEqual(config.env["API_KEY"], "secret123")
    }

    func test_mcpServerConfig_defaultEnv() {
        let config = MCPServerConfig(name: "s", command: "/bin/echo", args: [])
        XCTAssertTrue(config.env.isEmpty)
    }

    // MARK: - MCPClientManager: Registration

    func test_mcpClientManager_registerServer() async {
        let manager = MCPClientManager.shared
        let config = MCPServerConfig(name: "test-reg", command: "/bin/echo", args: [])
        await manager.registerServer(config)
        let servers = await manager.registeredServers
        XCTAssertTrue(servers.contains("test-reg"))
        // Cleanup
        try? await manager.unregisterServer(name: "test-reg")
    }

    func test_mcpClientManager_unregisterServer() async throws {
        let manager = MCPClientManager.shared
        let config = MCPServerConfig(name: "test-unreg", command: "/bin/echo", args: [])
        await manager.registerServer(config)
        try await manager.unregisterServer(name: "test-unreg")
        let servers = await manager.registeredServers
        XCTAssertFalse(servers.contains("test-unreg"))
    }

    func test_mcpClientManager_connectedServersInitiallyEmpty() async {
        let connected = await MCPClientManager.shared.connectedServers
        // We haven't connected any servers so the test-reg ones shouldn't be connected
        // This just verifies the property is accessible
        XCTAssertNotNil(connected)
    }

    func test_mcpClientManager_clientForUnknownServerReturnsNil() async {
        let client = await MCPClientManager.shared.client(for: "nonexistent-server-xyz")
        XCTAssertNil(client)
    }

    func test_mcpClientManager_serverForToolReturnsNilWhenNotMapped() async {
        let server = await MCPClientManager.shared.serverForTool(name: "unmapped_tool_xyz")
        XCTAssertNil(server)
    }

    func test_mcpClientManager_connectThrowsForUnregistered() async {
        do {
            try await MCPClientManager.shared.connect(serverName: "never-registered-server")
            XCTFail("Expected MCPError.serverNotFound")
        } catch let error as MCPError {
            if case .serverNotFound(let name) = error {
                XCTAssertEqual(name, "never-registered-server")
            } else {
                XCTFail("Expected serverNotFound, got \(error)")
            }
        } catch {
            XCTFail("Expected MCPError, got \(error)")
        }
    }

    func test_mcpClientManager_callToolThrowsForUnknownTool() async {
        do {
            _ = try await MCPClientManager.shared.callTool(name: "totally_fake_tool")
            XCTFail("Expected MCPError.unknownTool")
        } catch let error as MCPError {
            if case .unknownTool(let name) = error {
                XCTAssertEqual(name, "totally_fake_tool")
            } else {
                XCTFail("Expected unknownTool, got \(error)")
            }
        } catch {
            XCTFail("Expected MCPError, got \(error)")
        }
    }

    func test_mcpClientManager_callToolOnServerThrowsForUnconnected() async {
        do {
            _ = try await MCPClientManager.shared.callTool(
                serverName: "not-connected-server",
                toolName: "some_tool"
            )
            XCTFail("Expected MCPError.serverNotFound")
        } catch let error as MCPError {
            if case .serverNotFound = error {
                // Expected
            } else {
                XCTFail("Expected serverNotFound, got \(error)")
            }
        } catch {
            XCTFail("Expected MCPError, got \(error)")
        }
    }

    // MARK: - MCPToolBridge: Singleton and Initial State

    func test_mcpToolBridge_singletonExists() {
        let bridge = MCPToolBridge.shared
        XCTAssertNotNil(bridge)
    }

    func test_mcpToolBridge_initiallyNoRegisteredTools() {
        let bridge = MCPToolBridge.shared
        bridge.unregisterAllTools()
        let names = bridge.registeredToolNames
        XCTAssertTrue(names.isEmpty)
    }

    func test_mcpToolBridge_isMCPTool_prefixCheck() {
        let bridge = MCPToolBridge.shared
        bridge.unregisterAllTools()
        // Even with no tools registered, prefix check returns true
        let isPrefixed = bridge.isMCPTool("mcp_something")
        XCTAssertTrue(isPrefixed)
    }

    func test_mcpToolBridge_isMCPTool_unknownReturnsFalse() {
        let bridge = MCPToolBridge.shared
        bridge.unregisterAllTools()
        let result = bridge.isMCPTool("regular_tool")
        XCTAssertFalse(result)
    }

    func test_mcpToolBridge_toolInfoReturnsNilForUnknown() {
        let bridge = MCPToolBridge.shared
        bridge.unregisterAllTools()
        let info = bridge.toolInfo(for: "nonexistent_tool")
        XCTAssertNil(info)
    }

    func test_mcpToolBridge_getMCPToolDescriptionsEmpty() {
        let bridge = MCPToolBridge.shared
        bridge.unregisterAllTools()
        let descs = bridge.getMCPToolDescriptions()
        XCTAssertTrue(descs.isEmpty)
    }

    func test_mcpToolBridge_getFormattedToolListHeader() {
        let bridge = MCPToolBridge.shared
        bridge.unregisterAllTools()
        let formatted = bridge.getFormattedToolList()
        XCTAssertTrue(formatted.contains("MCP Tools:"))
    }

    // MARK: - MCPToolHandler: No tool name

    func test_mcpToolHandler_executeWithNilAction() async {
        let handler = MCPToolHandler()
        let result = await handler.execute(action: nil, params: [:])
        let success = result.success
        XCTAssertFalse(success)
        XCTAssertNotNil(result.error)
        XCTAssertTrue(result.error!.contains("No MCP tool name"))
    }

    // MARK: - MCPTypes: MCPTool identity

    func test_mcpTool_identityIsName() throws {
        let json = """
        {"name": "search", "description": "Search docs", "inputSchema": {"type": "object"}}
        """.data(using: .utf8)!
        let tool = try JSONDecoder().decode(MCPTool.self, from: json)
        XCTAssertEqual(tool.id, tool.name)
    }

    // MARK: - MCPTypes: MCPResource identity

    func test_mcpResource_identityIsUri() throws {
        let json = """
        {"uri": "notion://page/123", "name": "My Page"}
        """.data(using: .utf8)!
        let resource = try JSONDecoder().decode(MCPResource.self, from: json)
        XCTAssertEqual(resource.id, resource.uri)
    }

    // MARK: - MCPTypes: MCPPrompt identity

    func test_mcpPrompt_identityIsName() throws {
        let json = """
        {"name": "debug", "description": "Debug prompt"}
        """.data(using: .utf8)!
        let prompt = try JSONDecoder().decode(MCPPrompt.self, from: json)
        XCTAssertEqual(prompt.id, prompt.name)
    }

    // MARK: - AnyCodable: Edge case - empty string

    func test_anyCodable_emptyString() throws {
        let value = AnyCodable("")
        let data = try JSONEncoder().encode(value)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        XCTAssertEqual(decoded.stringValue, "")
    }

    // MARK: - AnyCodable: Edge case - negative numbers

    func test_anyCodable_negativeInt() throws {
        let value = AnyCodable(-99)
        let data = try JSONEncoder().encode(value)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        XCTAssertEqual(decoded.intValue, -99)
    }

    // MARK: - AnyCodable: Edge case - zero

    func test_anyCodable_zero() throws {
        let value = AnyCodable(0)
        let data = try JSONEncoder().encode(value)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        XCTAssertEqual(decoded.intValue, 0)
    }
}
