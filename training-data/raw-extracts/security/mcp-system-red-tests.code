    // MARK: - MCPTypes: MCPToolInputSchema

    func test_mcpToolInputSchema_codableRoundtrip() throws {
        let json = """
        {
            "type": "object",
            "properties": {
                "query": {"type": "string", "description": "Search query"},
                "limit": {"type": "integer"}
            },
            "required": ["query"]
        }
        """.data(using: .utf8)!
        let schema = try JSONDecoder().decode(MCPToolInputSchema.self, from: json)
        XCTAssertEqual(schema.type, "object")
        XCTAssertEqual(schema.properties?.count, 2)
        XCTAssertEqual(schema.properties?["query"]?.type, "string")
        XCTAssertEqual(schema.required, ["query"])
    }

    // MARK: - MCPTypes: MCPEmbeddedResource

