    func test_mcpPromptResult_codable() throws {
        let json = """
        {
            "description": "A greeting prompt",
            "messages": [
                {"role": "assistant", "content": {"type": "text", "text": "Hi there!"}}
            ]
        }
        """.data(using: .utf8)!
        let result = try JSONDecoder().decode(MCPPromptResult.self, from: json)
