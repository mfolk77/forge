    func test_mcpPropertySchema_nestedProperties() {
        let inner = MCPPropertySchema(type: "integer")
        let outer = MCPPropertySchema(type: "object", properties: ["count": inner])
        XCTAssertEqual(outer.properties?["count"]?.type, "integer")
