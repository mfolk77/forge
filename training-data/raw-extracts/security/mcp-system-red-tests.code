import XCTest
@testable import SerenaCore

/// Comprehensive red tests for MCP system files not covered by MCPClientRedTests.
///
/// Target files:
/// - Sources/SerenaCore/Services/MCP/JSONRPCTypes.swift
/// - Sources/SerenaCore/Services/MCP/MCPTypes.swift
/// - Sources/SerenaCore/Services/MCP/AnyCodable.swift
/// - Sources/SerenaCore/Services/MCP/MCPTransport.swift
/// - Sources/SerenaCore/Services/MCP/MCPToolBridge.swift
/// - Sources/SerenaCore/Services/MCP/MCPClientManager.swift
@MainActor
final class MCPSystemRedTests: XCTestCase {

    // MARK: - AnyCodable: Encoding/Decoding Roundtrips

    func test_anyCodable_stringRoundtrip() throws {
        let original = AnyCodable("hello")
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        XCTAssertEqual(decoded.stringValue, "hello")
    }

    func test_anyCodable_intRoundtrip() throws {
        let original = AnyCodable(42)
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        XCTAssertEqual(decoded.intValue, 42)
    }

    func test_anyCodable_doubleRoundtrip() throws {
        let original = AnyCodable(3.14)
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        let value = decoded.doubleValue
        XCTAssertNotNil(value)
        XCTAssertEqual(value!, 3.14, accuracy: 0.001)
    }

    func test_anyCodable_boolRoundtrip() throws {
        let original = AnyCodable(true)
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        XCTAssertEqual(decoded.boolValue, true)
    }

    func test_anyCodable_nullRoundtrip() throws {
        let original = AnyCodable(NSNull())
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        let isNull = decoded.isNull
        XCTAssertTrue(isNull)
    }

    func test_anyCodable_arrayRoundtrip() throws {
        let original = AnyCodable([1, 2, 3])
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        let arr = decoded.arrayValue
        XCTAssertNotNil(arr)
        XCTAssertEqual(arr?.count, 3)
    }

    func test_anyCodable_dictionaryRoundtrip() throws {
        let original = AnyCodable(["key": "value"])
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        let dict = decoded.dictionaryValue
        XCTAssertNotNil(dict)
        XCTAssertEqual(dict?["key"] as? String, "value")
    }

    func test_anyCodable_nestedDictionaryRoundtrip() throws {
        let original = AnyCodable(["outer": ["inner": 99]])
        let data = try JSONEncoder().encode(original)
        let decoded = try JSONDecoder().decode(AnyCodable.self, from: data)
        let dict = decoded.dictionaryValue
        let inner = dict?["outer"] as? [String: Any]
        XCTAssertNotNil(inner)
        XCTAssertEqual(inner?["inner"] as? Int, 99)
    }

    // MARK: - AnyCodable: ExpressibleBy Literals

    func test_anyCodable_nilLiteral() {
        let value: AnyCodable = nil
        let isNull = value.isNull
        XCTAssertTrue(isNull)
    }

    func test_anyCodable_boolLiteral() {
        let value: AnyCodable = true
        XCTAssertEqual(value.boolValue, true)
    }

    func test_anyCodable_intLiteral() {
        let value: AnyCodable = 42
        XCTAssertEqual(value.intValue, 42)
    }

    func test_anyCodable_floatLiteral() {
        let value: AnyCodable = 2.718
        let dv = value.doubleValue
        XCTAssertNotNil(dv)
        XCTAssertEqual(dv!, 2.718, accuracy: 0.001)
    }

    func test_anyCodable_stringLiteral() {
        let value: AnyCodable = "test"
        XCTAssertEqual(value.stringValue, "test")
    }

    func test_anyCodable_arrayLiteral() {
        let value: AnyCodable = [1, "two", 3.0]
        let arr = value.arrayValue
        XCTAssertNotNil(arr)
        XCTAssertEqual(arr?.count, 3)
    }

    func test_anyCodable_dictionaryLiteral() {
        let value: AnyCodable = ["a": 1, "b": "two"]
        let dict = value.dictionaryValue
        XCTAssertNotNil(dict)
        XCTAssertEqual(dict?["a"] as? Int, 1)
        XCTAssertEqual(dict?["b"] as? String, "two")
    }

    // MARK: - AnyCodable: Equatable

    func test_anyCodable_equalStrings() {
        let a: AnyCodable = "hello"
        let b: AnyCodable = "hello"
        XCTAssertEqual(a, b)
    }

    func test_anyCodable_unequalStrings() {
        let a: AnyCodable = "hello"
        let b: AnyCodable = "world"
        XCTAssertNotEqual(a, b)
    }

    func test_anyCodable_equalInts() {
        let a: AnyCodable = 7
        let b: AnyCodable = 7
        XCTAssertEqual(a, b)
    }

    func test_anyCodable_equalBools() {
        let a: AnyCodable = false
        let b: AnyCodable = false
        XCTAssertEqual(a, b)
    }

    func test_anyCodable_equalDoubles() {
        let a: AnyCodable = 1.5
        let b: AnyCodable = 1.5
        XCTAssertEqual(a, b)
    }

    func test_anyCodable_equalNulls() {
        let a: AnyCodable = nil
        let b: AnyCodable = nil
        XCTAssertEqual(a, b)
    }

    func test_anyCodable_differentTypesNotEqual() {
        let a: AnyCodable = 42
        let b: AnyCodable = "42"
        XCTAssertNotEqual(a, b)
    }

    // MARK: - AnyCodable: CustomStringConvertible

    func test_anyCodable_descriptionNull() {
        let value: AnyCodable = nil
        XCTAssertEqual(value.description, "null")
    }

    func test_anyCodable_descriptionBool() {
        let t: AnyCodable = true
        let f: AnyCodable = false
        XCTAssertEqual(t.description, "true")
        XCTAssertEqual(f.description, "false")
    }

    func test_anyCodable_descriptionInt() {
        let value: AnyCodable = 123
        XCTAssertEqual(value.description, "123")
    }

    func test_anyCodable_descriptionString() {
        let value: AnyCodable = "hi"
        XCTAssertEqual(value.description, "\"hi\"")
    }

    func test_anyCodable_descriptionArray() {
        let value = AnyCodable([1, 2])
        XCTAssertEqual(value.description, "[2 items]")
    }

    func test_anyCodable_descriptionDict() {
        let value = AnyCodable(["a": 1])
        XCTAssertEqual(value.description, "{1 keys}")
    }

    // MARK: - AnyCodable: Hashable

    func test_anyCodable_hashableConsistency() {
        let a: AnyCodable = "test"
        let b: AnyCodable = "test"
        XCTAssertEqual(a.hashValue, b.hashValue)
    }

    func test_anyCodable_usableInSet() {
        var set: Set<AnyCodable> = []
        set.insert(AnyCodable("a"))
        set.insert(AnyCodable("a"))
        set.insert(AnyCodable("b"))
        XCTAssertEqual(set.count, 2)
    }

    // MARK: - AnyCodable: Accessor Returns nil for Wrong Type

    func test_anyCodable_stringAccessorReturnsNilForInt() {
        let value: AnyCodable = 42
        XCTAssertNil(value.stringValue)
    }

    func test_anyCodable_intAccessorReturnsNilForString() {
        let value: AnyCodable = "hello"
        XCTAssertNil(value.intValue)
    }

    func test_anyCodable_boolAccessorReturnsNilForString() {
        let value: AnyCodable = "true"
        XCTAssertNil(value.boolValue)
    }

    func test_anyCodable_arrayAccessorReturnsNilForString() {
        let value: AnyCodable = "not an array"
        XCTAssertNil(value.arrayValue)
    }

    func test_anyCodable_dictAccessorReturnsNilForInt() {
        let value: AnyCodable = 5
        XCTAssertNil(value.dictionaryValue)
    }

    // MARK: - JSONRPCTypes: Request with [String: Any] params init

    func test_jsonRPCRequest_anyParamsInit() throws {
        let params: [String: Any] = ["name": "test_tool", "count": 3]
        let request = JSONRPCRequest(id: 10, method: "tools/call", params: params)
        XCTAssertEqual(request.id, 10)
        XCTAssertEqual(request.method, "tools/call")
        XCTAssertNotNil(request.params)
        XCTAssertEqual(request.params?["name"]?.stringValue, "test_tool")
    }

    func test_jsonRPCRequest_nilAnyParams() {
        let request = JSONRPCRequest(id: 1, method: "ping", params: nil as [String: Any]?)
        XCTAssertNil(request.params)
    }

    // MARK: - JSONRPCTypes: Notification with [String: Any] params init

    func test_jsonRPCNotification_anyParamsInit() {
        let params: [String: Any] = ["key": "value"]
        let notification = JSONRPCNotification(method: "test/notify", params: params)
        XCTAssertEqual(notification.jsonrpc, "2.0")
        XCTAssertEqual(notification.method, "test/notify")
        XCTAssertEqual(notification.params?["key"]?.stringValue, "value")
    }

    func test_jsonRPCNotification_nilAnyParams() {
        let notification = JSONRPCNotification(method: "test", params: nil as [String: Any]?)
        XCTAssertNil(notification.params)
    }

    func test_jsonRPCNotification_encodeToLine() throws {
        let notification = JSONRPCNotification(method: "initialized")
        let data = try notification.encodeToLine()
        let text = String(data: data, encoding: .utf8)!
        XCTAssertTrue(text.hasSuffix("\n"))
        XCTAssertTrue(text.contains("initialized"))
    }

    // MARK: - JSONRPCTypes: Codable Roundtrip

    func test_jsonRPCRequest_codableRoundtrip() throws {
        let request = JSONRPCRequest(id: 99, method: "resources/read", params: [
            "uri": AnyCodable("file:///test.txt")
        ])
        let data = try JSONEncoder().encode(request)
        let decoded = try JSONDecoder().decode(JSONRPCRequest.self, from: data)
        XCTAssertEqual(decoded.id, 99)
        XCTAssertEqual(decoded.method, "resources/read")
        XCTAssertEqual(decoded.jsonrpc, "2.0")
        XCTAssertEqual(decoded.params?["uri"]?.stringValue, "file:///test.txt")
    }

    func test_jsonRPCNotification_codableRoundtrip() throws {
        let notification = JSONRPCNotification(method: "notifications/tools/list_changed")
        let data = try JSONEncoder().encode(notification)
        let decoded = try JSONDecoder().decode(JSONRPCNotification.self, from: data)
        XCTAssertEqual(decoded.method, "notifications/tools/list_changed")
        XCTAssertEqual(decoded.jsonrpc, "2.0")
    }

    // MARK: - JSONRPCTypes: Response decoding edge cases

    func test_jsonRPCResponse_nullResult() throws {
        let json = """
        {"jsonrpc": "2.0", "id": 1, "result": null}
        """.data(using: .utf8)!
        let response = try JSONDecoder().decode(JSONRPCResponse.self, from: json)
        // "result": null decodes as Optional<AnyCodable>.none
        let isError = response.isError
        XCTAssertFalse(isError, "No error field, so isError should be false")
        // result is nil from null JSON, so isSuccess = false (isSuccess = error == nil && result != nil)
        let isSuccess = response.isSuccess
        XCTAssertFalse(isSuccess, "null result means result is nil")
    }

    func test_jsonRPCResponse_errorWithData() throws {
        let json = """
        {"jsonrpc": "2.0", "id": 1, "error": {"code": -32000, "message": "Custom error", "data": {"detail": "extra info"}}}
        """.data(using: .utf8)!
        let response = try JSONDecoder().decode(JSONRPCResponse.self, from: json)
        let isError = response.isError
        XCTAssertTrue(isError)
        XCTAssertEqual(response.error?.code, -32000)
        XCTAssertEqual(response.error?.message, "Custom error")
        XCTAssertNotNil(response.error?.data)
    }

    func test_jsonRPCResponse_noIdAllowed() throws {
        // Responses to notifications may lack an id
        let json = """
        {"jsonrpc": "2.0", "result": "ok"}
        """.data(using: .utf8)!
        let response = try JSONDecoder().decode(JSONRPCResponse.self, from: json)
        XCTAssertNil(response.id)
    }

    // MARK: - JSONRPCDecodingError

    func test_jsonRPCDecodingError_noResult_description() {
        let error = JSONRPCDecodingError.noResult
        let desc = error.errorDescription
        XCTAssertNotNil(desc)
        XCTAssertTrue(desc!.contains("no result"))
    }

    func test_jsonRPCDecodingError_invalidResultType_description() {
        let error = JSONRPCDecodingError.invalidResultType
        let desc = error.errorDescription
        XCTAssertNotNil(desc)
        XCTAssertTrue(desc!.contains("type"))
    }

    func test_jsonRPCDecodingError_decodingFailed_description() {
        let underlying = NSError(domain: "test", code: 1, userInfo: [NSLocalizedDescriptionKey: "bad data"])
        let error = JSONRPCDecodingError.decodingFailed(underlying)
        let desc = error.errorDescription
        XCTAssertNotNil(desc)
        XCTAssertTrue(desc!.contains("decode") || desc!.contains("Decode"))
    }

    // MARK: - JSONRPCError: Codable roundtrip

    func test_jsonRPCError_codableRoundtrip() throws {
        let error = JSONRPCError(code: -32601, message: "Method not found", data: AnyCodable("extra"))
        let data = try JSONEncoder().encode(error)
        let decoded = try JSONDecoder().decode(JSONRPCError.self, from: data)
        XCTAssertEqual(decoded.code, -32601)
        XCTAssertEqual(decoded.message, "Method not found")
        XCTAssertEqual(decoded.data?.stringValue, "extra")
    }

    func test_jsonRPCError_nilData() throws {
        let error = JSONRPCError(code: -32700, message: "Parse error")
        let data = try JSONEncoder().encode(error)
        let decoded = try JSONDecoder().decode(JSONRPCError.self, from: data)
        XCTAssertEqual(decoded.code, -32700)
        XCTAssertNil(decoded.data)
    }

    // MARK: - MCPTypes: MCPContent Codable

    func test_mcpContent_textCodableRoundtrip() throws {
        let content = MCPContent(text: "Hello MCP")
        let data = try JSONEncoder().encode(content)
        let decoded = try JSONDecoder().decode(MCPContent.self, from: data)
        XCTAssertEqual(decoded.type, .text)
        XCTAssertEqual(decoded.text, "Hello MCP")
        XCTAssertNil(decoded.data)
    }

    func test_mcpContent_imageCodableRoundtrip() throws {
        let content = MCPContent(imageData: "aGVsbG8=", mimeType: "image/jpeg")
        let data = try JSONEncoder().encode(content)
        let decoded = try JSONDecoder().decode(MCPContent.self, from: data)
        XCTAssertEqual(decoded.type, .image)
        XCTAssertEqual(decoded.data, "aGVsbG8=")
        XCTAssertEqual(decoded.mimeType, "image/jpeg")
    }

    func test_mcpContentType_rawValues() {
        XCTAssertEqual(MCPContent.MCPContentType.text.rawValue, "text")
        XCTAssertEqual(MCPContent.MCPContentType.image.rawValue, "image")
        XCTAssertEqual(MCPContent.MCPContentType.resource.rawValue, "resource")
    }

    // MARK: - MCPTypes: MCPToolResult

    func test_mcpToolResult_emptyContent() {
        let result = MCPToolResult(content: [])
        XCTAssertEqual(result.textContent, "")
        XCTAssertNil(result.isError)
    }

    func test_mcpToolResult_mixedContent() {
        let result = MCPToolResult(content: [
            MCPContent(text: "first"),
            MCPContent(imageData: "img", mimeType: "image/png"),
            MCPContent(text: "third")
        ])
        // textContent should skip image (no text field)
        XCTAssertEqual(result.textContent, "first\nthird")
    }

    func test_mcpToolResult_codableRoundtrip() throws {
        let result = MCPToolResult(content: [MCPContent(text: "output")], isError: false)
        let data = try JSONEncoder().encode(result)
        let decoded = try JSONDecoder().decode(MCPToolResult.self, from: data)
        XCTAssertEqual(decoded.textContent, "output")
        XCTAssertEqual(decoded.isError, false)
    }

    // MARK: - MCPTypes: MCPPropertySchema

    func test_mcpPropertySchema_basicInit() {
        let schema = MCPPropertySchema(type: "string", description: "A file path")
        XCTAssertEqual(schema.type, "string")
        XCTAssertEqual(schema.description, "A file path")
        XCTAssertNil(schema.enum)
