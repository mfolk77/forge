    func test_mcpPropertySchema_enumValues() {
        let schema = MCPPropertySchema(type: "string", enum: ["json", "yaml", "xml"])
        XCTAssertEqual(schema.enum, ["json", "yaml", "xml"])
    }

    func test_mcpPropertySchema_nestedItems() {
        let itemSchema = MCPPropertySchema(type: "string")
        let arraySchema = MCPPropertySchema(type: "array", items: itemSchema)
        XCTAssertEqual(arraySchema.type, "array")
        XCTAssertEqual(arraySchema.items?.type, "string")
