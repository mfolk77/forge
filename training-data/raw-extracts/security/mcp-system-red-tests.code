    func test_mcpPropertySchema_codableRoundtrip() throws {
        let schema = MCPPropertySchema(type: "string", description: "test", enum: ["a", "b"])
        let data = try JSONEncoder().encode(schema)
        let decoded = try JSONDecoder().decode(MCPPropertySchema.self, from: data)
        XCTAssertEqual(decoded.type, "string")
        XCTAssertEqual(decoded.description, "test")
        XCTAssertEqual(decoded.enum, ["a", "b"])
