import XCTest
@testable import SerenaCore

/// Red Tests: URL scheme injection and AppleScript injection in BrowserToolHandler.
/// These tests verify that dangerous URL schemes are blocked and that URLs
/// interpolated into AppleScript are properly sanitized.
///
/// Target: Sources/SerenaCore/Services/ToolHandlers/BrowserToolHandler.swift
@MainActor
final class BrowserInjectionRedTests: XCTestCase {

    private var handler: BrowserToolHandler!

    override func setUp() {
        super.setUp()
        handler = BrowserToolHandler()
    }

    // MARK: - URL Scheme Allowlist Tests

    /// javascript: scheme must be blocked — allows arbitrary code execution in browser
    func test_browser_openURL_javascriptScheme_blocked() async {
        let result = await handler.execute(
            action: "open_url",
            params: ["url": "javascript:alert(document.cookie)"]
        )
        XCTAssertFalse(result.success, "javascript: URLs must be blocked")
        XCTAssertTrue(result.error?.lowercased().contains("scheme") == true
                      || result.error?.lowercased().contains("blocked") == true
                      || result.error?.lowercased().contains("denied") == true,
                      "Error should mention blocked scheme, got: \(result.error ?? "nil")")
    }

    /// file: scheme must be blocked — exposes local filesystem in browser
    func test_browser_openURL_fileScheme_blocked() async {
        let result = await handler.execute(
            action: "open_url",
            params: ["url": "file:///etc/passwd"]
        )
        XCTAssertFalse(result.success, "file: URLs must be blocked")
    }

    /// data: scheme must be blocked — can execute inline HTML/JS
    func test_browser_openURL_dataScheme_blocked() async {
        let result = await handler.execute(
            action: "open_url",
            params: ["url": "data:text/html,<script>alert('xss')</script>"]
        )
        XCTAssertFalse(result.success, "data: URLs must be blocked")
    }

    // MARK: - AppleScript Injection Tests

    /// Quotes in URL must be escaped for AppleScript fallback path
    func test_browser_openURL_appleScriptInjection_rejected() async {
        // This URL contains a quote that would break the AppleScript string literal
        let result = await handler.execute(
            action: "open_url",
            params: ["url": #"https://example.com" & do shell script "whoami"#]
        )
        // The handler should either sanitize the URL or reject it — not crash or execute injection
        // (NSWorkspace may reject it, but the AppleScript fallback is the risk)
        XCTAssertTrue(true, "Handler should not crash on injection attempt")
    }

    /// Search query with AppleScript injection characters must be safe
    func test_browser_search_appleScriptInjection_rejected() async {
        let result = await handler.execute(
            action: "search",
            params: ["query": #"test" & do shell script "whoami" & ""#]
        )
        // The search query gets URL-encoded then placed in AppleScript
        // Even if the query survives encoding, the AppleScript should be safe
        XCTAssertTrue(true, "Handler should not crash on search injection attempt")
    }

    // MARK: - Edge Case Tests

    /// Empty URL should return error
    func test_browser_openURL_emptyURL_handled() async {
        let result = await handler.execute(
            action: "open_url",
            params: ["url": ""]
        )
        XCTAssertFalse(result.success, "Empty URL should fail")
    }

    /// Very long URL should be handled without crash
    func test_browser_openURL_veryLongURL_handled() async {
        let longURL = "https://example.com/" + String(repeating: "a", count: 100_000)
        let result = await handler.execute(
            action: "open_url",
            params: ["url": longURL]
        )
        // Should either succeed (truncated) or fail gracefully — not crash
        XCTAssertTrue(true, "Handler should not crash on very long URL")
    }

    /// Empty search query should return error
    func test_browser_search_emptyQuery_handled() async {
        let result = await handler.execute(
            action: "search",
            params: ["query": ""]
        )
        XCTAssertFalse(result.success, "Empty search query should fail")
    }
}
