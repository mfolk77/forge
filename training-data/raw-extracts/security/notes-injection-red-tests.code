import XCTest
@testable import SerenaCore

/// Red Tests: AppleScript injection attacks against NotesToolHandler.
/// These tests verify that `sanitizeForAppleScript()` on ToolHelpers
/// prevents injection in all Notes operations.
///
/// Target: Sources/SerenaCore/Services/ToolHandlers/ToolHelpers.swift
///         Sources/SerenaCore/Services/ToolHandlers/NotesToolHandler.swift
@MainActor
final class NotesInjectionRedTests: XCTestCase {

    private var helpers: ToolHelpers!

    override func setUp() {
        super.setUp()
        helpers = ToolHelpers.shared
    }

    // MARK: - sanitizeForAppleScript() Unit Tests

    /// The core sanitizer must make shell command breakout safe by escaping quotes.
    /// When interpolated into an AppleScript string literal, the escaped content
    /// stays as literal text — never as executable commands.
    func test_sanitize_appleScriptBreakout_stripped() {
        let input = AttackPayloads.appleScriptBreakout
        let sanitized = helpers.sanitizeForAppleScript(input)

        // All quotes in the output must be properly escaped (preceded by \)
        assertNoAppleScriptBreakout(sanitized)
    }

    /// Newline injection should be stripped — newlines can break AppleScript string context
    func test_sanitize_newlineInjection_stripped() {
        let input = AttackPayloads.appleScriptNewlineBreakout
        let sanitized = helpers.sanitizeForAppleScript(input)

        XCTAssertFalse(sanitized.contains("\n"), "Newlines must be stripped")
        XCTAssertFalse(sanitized.contains("\r"), "Carriage returns must be stripped")
        // The text "tell application" may remain as escaped literal content — that's safe.
        // What matters is that it can't execute because quotes are escaped and there are no newlines.
        assertNoAppleScriptBreakout(sanitized)
    }

    /// Backslash-quote chains must not defeat escaping.
    /// Input: test\\" (backslash-backslash-quote)
    /// The concern is that escaping `\` first to `\\` might cause the subsequent
    /// `"` escaping to produce `\\"` which looks like an escaped backslash + bare quote.
    /// Correct: `\` → `\\`, then `"` → `\"`, final: `\\\\"` (two escaped backslashes + escaped quote)
    func test_sanitize_backslashQuoteChain_safe() {
        let input = AttackPayloads.appleScriptBackslashChain // raw: test\\"
        let sanitized = helpers.sanitizeForAppleScript(input)

        // All quotes must be properly escaped in the result
        assertNoAppleScriptBreakout(sanitized)
    }

    /// Unicode fullwidth quotes (U+FF02) should be normalized or stripped
    func test_sanitize_unicodeQuote_normalized() {
        let input = AttackPayloads.unicodeFullwidthQuote
        let sanitized = helpers.sanitizeForAppleScript(input)

        // The fullwidth quote should either be escaped or replaced
        XCTAssertFalse(sanitized.contains("\u{FF02}"),
                        "Fullwidth quotation mark must be normalized/escaped")
    }

    /// Null bytes should be completely removed
    func test_sanitize_nullByte_stripped() {
        let input = AttackPayloads.nullByteInTitle
        let sanitized = helpers.sanitizeForAppleScript(input)

        XCTAssertFalse(sanitized.contains("\0"), "Null bytes must be stripped")
        XCTAssertTrue(sanitized.contains("test"), "Non-null content should be preserved")
    }

    /// Very long strings should be truncated to prevent DoS
    func test_sanitize_maxLength_truncated() {
        let input = AttackPayloads.longString100K
        let sanitized = helpers.sanitizeForAppleScript(input)

        XCTAssertLessThanOrEqual(sanitized.count, 10_000,
                                  "Strings over 10K chars should be truncated for AppleScript safety")
    }

    /// Empty string should pass through (handlers decide what to do with it)
    func test_sanitize_emptyString_preserved() {
        let sanitized = helpers.sanitizeForAppleScript("")
        XCTAssertEqual(sanitized, "", "Empty string should remain empty")
    }

    /// Whitespace-only string should be trimmed to empty
    func test_sanitize_whitespaceOnly_trimmed() {
        let sanitized = helpers.sanitizeForAppleScript("   \t\n  ")
        XCTAssertTrue(sanitized.trimmingCharacters(in: .whitespaces).isEmpty,
                       "Whitespace-only input should be trimmed")
    }

    /// Regular text with special chars should be properly escaped
    func test_sanitize_specialChars_escaped() {
        let input = "John's \"meeting\" & notes"
        let sanitized = helpers.sanitizeForAppleScript(input)

        // All quotes must be properly escaped
        assertNoAppleScriptBreakout(sanitized)
        // The apostrophe and & should survive (they're safe in AppleScript strings)
        XCTAssertTrue(sanitized.contains("'"), "Apostrophe should be preserved")
        XCTAssertTrue(sanitized.contains("&"), "Ampersand should be preserved")
    }

    /// AppleScript keywords used as literal text should be safe
    func test_sanitize_embeddedKeywords_safe() {
        let input = AttackPayloads.appleScriptKeywordTitle
        let sanitized = helpers.sanitizeForAppleScript(input)

        // The text "tell application Safari to quit" as a note title
        // should be safe when properly quoted — check the sanitized content directly
        assertNoAppleScriptBreakout(sanitized)
        // The words should survive as literal text (they're not dangerous inside a string)
        XCTAssertTrue(sanitized.contains("tell"), "Keyword text should be preserved as literal")
    }

    // MARK: - NotesToolHandler Integration Tests
    // These test that NotesToolHandler actually USES sanitizeForAppleScript()

    /// Create note with injection in title — should be safe
    func test_notes_createTitle_appleScriptBreakout_rejected() async {
        let handler = NotesToolHandler()
        // We can't test the actual AppleScript execution (no Notes.app in tests),
        // but we can verify the handler doesn't crash and returns a result
        let result = await handler.execute(
            action: "create",
            params: ["title": AttackPayloads.appleScriptBreakout, "content": "safe content"]
        )
        // The handler may fail (no Notes.app) but should NOT crash
        // What matters is the script it would generate is safe
        XCTAssertTrue(true, "Handler should not crash on injection attempt")
    }

    /// Create note with empty title should get a default
    func test_notes_createTitle_emptyString_handled() async {
        let handler = NotesToolHandler()
        let result = await handler.execute(
            action: "create",
            params: ["title": "", "content": "some content"]
        )
        // Empty title should either succeed with "Untitled Note" or return useful error
        // It should NOT crash
        XCTAssertTrue(true, "Handler should not crash on empty title")
    }

    /// Create note with only whitespace title
    func test_notes_createTitle_onlyWhitespace_handled() async {
        let handler = NotesToolHandler()
        let result = await handler.execute(
            action: "create",
            params: ["title": "   \t\n  ", "content": "some content"]
        )
        XCTAssertTrue(true, "Handler should not crash on whitespace-only title")
    }

    /// Read note with injection in title — should not manipulate predicate
    func test_notes_readTitle_appleScriptInjection_rejected() async {
        let handler = NotesToolHandler()
        let result = await handler.execute(
            action: "read",
            params: ["title": "\" or name contains \""]
        )
        XCTAssertTrue(true, "Handler should not crash on injection attempt")
    }

    /// HTML tags in content should be escaped (Notes uses HTML body)
    func test_notes_appendContent_htmlInjection_rejected() async {
        let handler = NotesToolHandler()
        let result = await handler.execute(
            action: "append",
            params: ["title": "Test Note", "content": AttackPayloads.htmlScriptTag]
        )
        XCTAssertTrue(true, "Handler should not crash on HTML injection attempt")
    }

    /// Delete with empty title should NOT delete first note found
    func test_notes_deleteTitle_emptyTitle_rejected() async {
        let handler = NotesToolHandler()
        let result = await handler.execute(
            action: "delete",
            params: ["title": ""]
        )
        // Empty title should be rejected, not match everything
        XCTAssertFalse(result.success, "Empty title should be rejected for delete")
    }
}
