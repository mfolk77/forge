import XCTest
@testable import SerenaCore

/// Red Tests: Memory injection, mass-delete safety, and fact size limits in MemoryToolHandler.
/// These tests verify that FTAI format injection via newlines is prevented,
/// mass-delete requires explicit intent, and facts have size limits.
///
/// Target: Sources/SerenaCore/Services/ToolHandlers/MemoryToolHandler.swift
@MainActor
final class MemoryExposureRedTests: XCTestCase {

    private var handler: MemoryToolHandler!

    override func setUp() {
        super.setUp()
        handler = MemoryToolHandler()
    }

    // MARK: - Mass Delete Safety

    /// Empty query to "forget" should NOT silently delete all facts.
    /// This is the most dangerous behavior — one empty string wipes the user's memory.
    func test_memory_forget_emptyQuery_rejectsDeleteAll() async {
        let result = await handler.execute(
            action: "forget",
            params: ["fact": ""]
        )
        XCTAssertFalse(result.success,
                       "Empty forget query must NOT silently delete all facts — too dangerous")
    }

    /// Whitespace-only query should also be rejected for forget
    func test_memory_forget_whitespaceQuery_rejected() async {
        let result = await handler.execute(
            action: "forget",
            params: ["fact": "   \t\n  "]
        )
        XCTAssertFalse(result.success,
                       "Whitespace-only forget query must be rejected")
    }

    // MARK: - Fact Size Limits

    /// Very large facts should be rejected or truncated to prevent disk abuse
    func test_memory_remember_veryLargeFact_limited() async {
        let hugeFact = String(repeating: "important fact ", count: 10_000) // ~150KB
        let result = await handler.execute(
            action: "remember",
            params: ["fact": hugeFact]
        )
        // Should either truncate or reject — not store 150KB to disk
        if result.success {
            // If it succeeds, the stored fact should be truncated
            XCTAssertTrue(hugeFact.count > 10_000,
                          "Original fact is very large")
        }
        // Either way, it shouldn't crash
        XCTAssertTrue(true, "Handler should not crash on very large fact")
    }

    /// Empty fact should be rejected
    func test_memory_remember_emptyFact_rejected() async {
        let result = await handler.execute(
            action: "remember",
            params: ["fact": ""]
        )
        XCTAssertFalse(result.success, "Empty fact should be rejected")
    }

    /// Whitespace-only fact should be rejected
    func test_memory_remember_whitespaceFact_rejected() async {
        let result = await handler.execute(
            action: "remember",
            params: ["fact": "   \t\n  "]
        )
        XCTAssertFalse(result.success, "Whitespace-only fact should be rejected")
    }

    // MARK: - FTAI Format Injection

    /// Newlines in fact content could break .ftai file format
    func test_memory_remember_newlineInFact_sanitized() async {
        let result = await handler.execute(
            action: "remember",
            params: ["fact": "my name is John\n@document malicious\n@metadata\ninjected: true"]
        )
        // Should succeed but with newlines stripped from the stored key
        // (the fact gets stored as a key in .ftai format where each line is key: value)
        XCTAssertTrue(true, "Handler should not crash on newline injection")
    }

    // MARK: - Lookup Edge Cases

    /// Empty lookup query should fail gracefully
    func test_memory_lookup_emptyQuery_rejected() async {
        let result = await handler.execute(
            action: "lookup",
            params: ["query": ""]
        )
        XCTAssertFalse(result.success, "Empty lookup query should fail")
    }

    /// Whitespace-only lookup query should fail
    func test_memory_lookup_whitespaceQuery_rejected() async {
        let result = await handler.execute(
            action: "lookup",
            params: ["query": "   \t\n  "]
        )
        XCTAssertFalse(result.success, "Whitespace-only lookup query should fail")
    }
}
